<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">

  <Package
    Name="Modern ThinkPad LEDs Controller"
    Manufacturer="stanlrt"
    Version="1.0.0"
    UpgradeCode="12345678-1234-1234-1234-123456789ABC"
    Scope="perMachine">

    <MajorUpgrade DowngradeErrorMessage="A newer version is already installed." />

    <MediaTemplate EmbedCab="yes" />

    <!-- Icon for Add/Remove Programs -->
    <Icon Id="AppIcon.exe" SourceFile="$(PublishDir)\ModernThinkPadLEDsController.exe" />
    <Property Id="ARPPRODUCTICON" Value="AppIcon.exe" />

    <!-- Installation directory structure -->
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="Modern ThinkPad LEDs Controller">
        <Component>
          <File Source="$(PublishDir)\ModernThinkPadLEDsController.exe" />
        </Component>
        <Component>
          <File Source="$(PublishDir)\inpoutx64.dll" />
        </Component>
      </Directory>
    </StandardDirectory>

    <!-- Start Menu shortcut -->
    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="ApplicationProgramsFolder" Name="Modern ThinkPad LEDs Controller">
        <Component>
          <Shortcut
            Name="Modern ThinkPad LEDs Controller"
            Target="[INSTALLFOLDER]ModernThinkPadLEDsController.exe"
            WorkingDirectory="INSTALLFOLDER" />
          <RemoveFolder Id="ApplicationProgramsFolder" On="uninstall"/>
          <RegistryValue Root="HKCU" Key="Software\ModernThinkPadLEDsController" Name="installed" Type="integer" Value="1" KeyPath="yes"/>
        </Component>
      </Directory>
    </StandardDirectory>

    <!-- UI -->
    <ui:WixUI Id="WixUI_Minimal" />
    <WixVariable Id="WixUILicenseRtf" Value="License.rtf" />

  </Package>
</Wix>
