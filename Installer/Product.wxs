<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">

  <Package
    Name="Modern ThinkPad LEDs Controller"
    Manufacturer="Stanislas Laurent"
    Version="$(Version)"
    UpgradeCode="12345678-1234-1234-1234-123456789ABC"
    Scope="perMachine">

    <MajorUpgrade DowngradeErrorMessage="A newer version is already installed." />

    <MediaTemplate EmbedCab="yes" />

    <!-- Icon for Add/Remove Programs -->
    <Icon Id="AppIcon.exe" SourceFile="$(PublishDir)/ModernThinkPadLEDsController.exe" />
    <Property Id="ARPPRODUCTICON" Value="AppIcon.exe" />

    <!-- Properties for startup and launch -->
    <Property Id="WIXUI_EXITDIALOGOPTIONALCHECKBOXTEXT" Value="Start with Windows (can be changed later in Task Manager)" />
    <Property Id="WIXUI_EXITDIALOGOPTIONALCHECKBOX" Value="1" />

    <!-- Feature definition -->
    <Feature Id="ProductFeature" Title="Modern ThinkPad LEDs Controller" Level="1">
      <ComponentRef Id="MainExecutableComponent" />
      <ComponentRef Id="StartMenuShortcutComponent" />
      <ComponentRef Id="StartupRegistryComponent" />
    </Feature>

    <!-- Installation directory structure -->
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="Modern ThinkPad LEDs Controller">
        <Component Id="MainExecutableComponent" Guid="A1B2C3D4-5678-90AB-CDEF-111111111111">
          <File Id="MainExecutable" Source="$(PublishDir)/ModernThinkPadLEDsController.exe" KeyPath="yes" />
        </Component>
      </Directory>
    </StandardDirectory>

    <!-- Start Menu shortcut -->
    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="ApplicationProgramsFolder" Name="Modern ThinkPad LEDs Controller">
        <Component Id="StartMenuShortcutComponent" Guid="A1B2C3D4-5678-90AB-CDEF-222222222222">
          <Shortcut
            Id="StartMenuShortcut"
            Name="Modern ThinkPad LEDs Controller"
            Target="[INSTALLFOLDER]ModernThinkPadLEDsController.exe"
            WorkingDirectory="INSTALLFOLDER" />
          <RemoveFolder Id="ApplicationProgramsFolder" On="uninstall"/>
          <RegistryValue Root="HKCU" Key="Software\ModernThinkPadLEDsController" Name="installed" Type="integer" Value="1" KeyPath="yes"/>
        </Component>
      </Directory>
    </StandardDirectory>

    <!-- Startup with Windows registry entry (optional via checkbox) -->
    <Component Id="StartupRegistryComponent" Directory="INSTALLFOLDER" Guid="A1B2C3D4-5678-90AB-CDEF-333333333333" Condition="WIXUI_EXITDIALOGOPTIONALCHECKBOX = &quot;1&quot;">
      <RegistryValue
        Root="HKCU"
        Key="Software\Microsoft\Windows\CurrentVersion\Run"
        Name="ModernThinkPadLEDsController"
        Value="&quot;[INSTALLFOLDER]ModernThinkPadLEDsController.exe&quot;"
        Type="string"
        KeyPath="yes" />
    </Component>

    <!-- Custom action to launch application after install -->
    <CustomAction
      Id="LaunchApplication"
      FileRef="MainExecutable"
      ExeCommand=""
      Execute="immediate"
      Impersonate="yes"
      Return="asyncNoWait" />

    <InstallExecuteSequence>
      <Custom Action="LaunchApplication" After="InstallFinalize" Condition="NOT Installed AND NOT REMOVE" />
    </InstallExecuteSequence>

    <!-- UI -->
    <ui:WixUI Id="WixUI_Minimal" />
    <WixVariable Id="WixUILicenseRtf" Value="Installer/License.rtf" />

  </Package>
</Wix>
