<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">

  <!-- IMPORTANT: Never change the UpgradeCode -->
  <Package
    Name="Modern ThinkPad LEDs Controller"
    Manufacturer="Stanislas Laurent"
    Version="$(Version)"
    UpgradeCode="8FE4A13B-13B3-4571-834B-D1163F95D942"
    Scope="perMachine">

    <MajorUpgrade DowngradeErrorMessage="A newer version is already installed." />

    <MediaTemplate EmbedCab="yes" />

    <!-- Icon for Add/Remove Programs and shortcuts -->
    <Icon Id="AppIcon.ico" SourceFile="$(ProjectDir)/../ModernThinkPadLEDsController/Resources/favicon.ico" />
    <Property Id="ARPPRODUCTICON" Value="AppIcon.ico" />

    <!-- Exit dialog checkbox launches the app after a successful install -->
    <Property Id="WIXUI_EXITDIALOGOPTIONALCHECKBOXTEXT" Value="Launch Modern ThinkPad LEDs Controller" />
    <Property Id="WIXUI_EXITDIALOGOPTIONALCHECKBOX" Value="1" />

    <!-- Feature definition -->
    <Feature Id="ProductFeature" Title="Modern ThinkPad LEDs Controller" Level="1">
      <ComponentRef Id="MainExecutableComponent" />
      <ComponentRef Id="StartMenuShortcutComponent" />
    </Feature>

    <!-- Installation directory structure -->
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="Modern ThinkPad LEDs Controller">
        <Component Id="MainExecutableComponent" Guid="A1B2C3D4-5678-90AB-CDEF-111111111111">
          <File Id="MainExecutable" Source="$(PublishDir)/ModernThinkPadLEDsController.exe" KeyPath="yes" />
        </Component>
      </Directory>
    </StandardDirectory>

    <!-- Start Menu shortcut -->
    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="ApplicationProgramsFolder" Name="Modern ThinkPad LEDs Controller">
        <Component Id="StartMenuShortcutComponent" Guid="A1B2C3D4-5678-90AB-CDEF-222222222222">
          <Shortcut
            Id="StartMenuShortcut"
            Name="Modern ThinkPad LEDs Controller"
            Target="[INSTALLFOLDER]ModernThinkPadLEDsController.exe"
            WorkingDirectory="INSTALLFOLDER"
            Icon="AppIcon.ico" />
          <RemoveFolder Id="ApplicationProgramsFolder" On="uninstall"/>
          <RegistryValue Root="HKCU" Key="Software\ModernThinkPadLEDsController" Name="installed" Type="integer" Value="1" KeyPath="yes"/>
        </Component>
      </Directory>
    </StandardDirectory>

    <!-- Custom action to launch application after install -->
    <CustomAction
      Id="LaunchApplication"
      FileRef="MainExecutable"
      ExeCommand=""
      Execute="immediate"
      Impersonate="yes"
      Return="asyncNoWait" />

    <!-- UI -->
    <ui:WixUI Id="WixUI_Minimal" />
    <UI>
      <Publish
        Dialog="ExitDialog"
        Control="Finish"
        Event="DoAction"
        Value="LaunchApplication"
        Condition="WIXUI_EXITDIALOGOPTIONALCHECKBOX = 1 AND NOT Installed" />
    </UI>
    <WixVariable Id="WixUILicenseRtf" Value="Installer/License.rtf" />

  </Package>
</Wix>
