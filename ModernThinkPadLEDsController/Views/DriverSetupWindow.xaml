<ui:FluentWindow
    x:Class="ModernThinkPadLEDsController.Views.DriverSetupWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="Modern ThinkPad LEDs Controller — Driver Setup"
    Width="480" Height="260"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterScreen">

    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Driver Initialisation Required"
                   FontSize="20" FontWeight="SemiBold"
                   Margin="0,0,0,16"/>

        <TextBlock Grid.Row="1" TextWrapping="Wrap" Opacity="0.7">
            The InpOut kernel driver must be initialised before the app can
            communicate with the ThinkPad Embedded Controller.
            <LineBreak/><LineBreak/>
            Click <Bold>Initialise Driver</Bold> to install and start the driver service.
            This happens once — future launches are silent.
        </TextBlock>

        <TextBlock Grid.Row="2"
                   x:Name="StatusText"
                   Foreground="Red"
                   Margin="0,12,0,0"
                   Visibility="Collapsed"/>

        <Button Grid.Row="3"
                x:Name="InitButton"
                Content="Initialise Driver"
                HorizontalAlignment="Right"
                Margin="0,16,0,0"
                Padding="24,8"
                Click="InitButton_Click"/>
    </Grid>
</ui:FluentWindow>
