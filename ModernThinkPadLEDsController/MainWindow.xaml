<ui:FluentWindow
    x:Class="ModernThinkPadLEDsController.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:converters="clr-namespace:ModernThinkPadLEDsController.Converters"
    xmlns:root="clr-namespace:ModernThinkPadLEDsController"
    Title="Modern ThinkPad LEDs Controller"
    Width="1000"
    Height="700"
    MinWidth="640"
    MinHeight="400"
    WindowStartupLocation="CenterScreen"
    ShowInTaskbar="True"
    Icon="pack://application:,,,/Resources/favicon.ico"
    Closing="OnWindowClosing">

    <ui:FluentWindow.Resources>
        <converters:EnumToBoolConverter x:Key="EnumToBool"/>
        <converters:HexByteConverter x:Key="HexByte"/>
        <BooleanToVisibilityConverter  x:Key="BoolToVis"/>
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0"
                     Title="Modern ThinkPad LEDs Controller"/>

        <!-- Main vertical scroll for entire page -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      Padding="12"
                      PreviewMouseWheel="MainScrollViewer_PreviewMouseWheel">
            <StackPanel>

                <!-- ============================================================ -->
                <!-- SECTION 1 — LED mode table                                   -->
                <!-- ============================================================ -->
                <ui:Card Padding="12,10"
                         Margin="0,0,0,32">
                    <!-- Horizontal scroll for table only -->
                    <ScrollViewer x:Name="TableScrollViewer"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Disabled"
                                  PreviewMouseWheel="TableScrollViewer_PreviewMouseWheel"
                                  Padding="0,0,0,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <!-- LED name   -->
                                <ColumnDefinition Width="Auto"/>
                                <!-- Default    -->
                                <ColumnDefinition Width="Auto"/>
                                <!-- On         -->
                                <ColumnDefinition Width="Auto"/>
                                <!-- Off        -->
                                <ColumnDefinition Width="Auto"/>
                                <!-- Blink      -->
                                <ColumnDefinition Width="Auto"/>
                                <!-- Hotkey     -->
                                <ColumnDefinition Width="Auto"/>
                                <!-- Disk Write -->
                                <ColumnDefinition Width="Auto"/>
                                <!-- Disk Read  -->
                                <ColumnDefinition Width="Auto"/>
                                <!-- LED Mapping -->
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <!-- header     -->
                                <RowDefinition Height="Auto"/>
                                <!-- Power      -->
                                <RowDefinition Height="Auto"/>
                                <!-- Mute       -->
                                <RowDefinition Height="Auto"/>
                                <!-- Red Dot    -->
                                <RowDefinition Height="Auto"/>
                                <!-- Microphone -->
                                <RowDefinition Height="Auto"/>
                                <!-- Sleep      -->
                                <RowDefinition Height="Auto"/>
                                <!-- Fn Lock    -->
                                <RowDefinition Height="Auto"/>
                                <!-- Camera     -->
                            </Grid.RowDefinitions>

                            <!-- ── Header row ── -->
                            <TextBlock Grid.Row="0"
                                       Grid.Column="0"
                                       Text="LED"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Bottom"
                                       Margin="4,0,20,6"/>

                            <StackPanel Grid.Row="0"
                                        Grid.Column="1"
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Bottom"
                                        Margin="8,0,16,6">
                                <TextBlock Text="Default"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                                <Border Margin="7,0,0,0"
                                        Width="16"
                                        Height="16"
                                        CornerRadius="8"
                                        Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                        VerticalAlignment="Center"
                                        Cursor="Help"
                                        ToolTipService.ShowDuration="20000">
                                    <Border.ToolTip>
                                        <ToolTip>
                                            <TextBlock MaxWidth="240"
                                                       TextWrapping="Wrap"
                                                       Text="Let the LED follow the default OS behaviour."/>
                                        </ToolTip>
                                    </Border.ToolTip>
                                    <TextBlock Text="?"
                                               FontSize="10"
                                               FontWeight="SemiBold"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                </Border>
                            </StackPanel>

                            <TextBlock Grid.Row="0"
                                       Grid.Column="2"
                                       Text="On"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="Bottom"
                                       Margin="8,0,16,6"/>
                            <TextBlock Grid.Row="0"
                                       Grid.Column="3"
                                       Text="Off"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="Bottom"
                                       Margin="8,0,16,6"/>
                            <TextBlock Grid.Row="0"
                                       Grid.Column="4"
                                       Text="Blink"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="Bottom"
                                       Margin="8,0,16,6"/>

                            <StackPanel Grid.Row="0"
                                        Grid.Column="5"
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Bottom"
                                        Margin="8,0,16,6">
                                <TextBlock Text="Hotkey"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                                <Border Margin="7,0,0,0"
                                        Width="16"
                                        Height="16"
                                        CornerRadius="8"
                                        Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                        VerticalAlignment="Center"
                                        Cursor="Help"
                                        ToolTipService.ShowDuration="20000">
                                    <Border.ToolTip>
                                        <ToolTip>
                                            <TextBlock MaxWidth="240"
                                                       TextWrapping="Wrap"
                                                       Text="Make the LED cycle through the selected states each time the hotkey is pressed. Configure the states in the Hotkey tab below."/>
                                        </ToolTip>
                                    </Border.ToolTip>
                                    <TextBlock Text="?"
                                               FontSize="10"
                                               FontWeight="SemiBold"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                </Border>
                            </StackPanel>

                            <StackPanel Grid.Row="0"
                                        Grid.Column="6"
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Bottom"
                                        Margin="8,0,16,6">
                                <TextBlock Text="Disk Write"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                                <Border Margin="7,0,0,0"
                                        Width="16"
                                        Height="16"
                                        CornerRadius="8"
                                        Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                        VerticalAlignment="Center"
                                        Cursor="Help"
                                        ToolTipService.ShowDuration="20000">
                                    <Border.ToolTip>
                                        <ToolTip>
                                            <TextBlock MaxWidth="240"
                                                       TextWrapping="Wrap"
                                                       Text="LED turns on whenever a disk write is detected (HDD, SSD, NVMe, ...). Configure the polling interval in the Disk tab below."/>
                                        </ToolTip>
                                    </Border.ToolTip>
                                    <TextBlock Text="?"
                                               FontSize="10"
                                               FontWeight="SemiBold"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                </Border>
                            </StackPanel>

                            <StackPanel Grid.Row="0"
                                        Grid.Column="7"
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Bottom"
                                        Margin="8,0,0,6">
                                <TextBlock Text="Disk Read"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                                <Border Margin="7,0,0,0"
                                        Width="16"
                                        Height="16"
                                        CornerRadius="8"
                                        Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                        VerticalAlignment="Center"
                                        Cursor="Help"
                                        ToolTipService.ShowDuration="20000">
                                    <Border.ToolTip>
                                        <ToolTip>
                                            <TextBlock MaxWidth="240"
                                                       TextWrapping="Wrap"
                                                       Text="LED turns on whenever a disk read is detected (HDD, SSD, NVMe, ...). Configure the polling interval in the Disk tab below."/>
                                        </ToolTip>
                                    </Border.ToolTip>
                                    <TextBlock Text="?"
                                               FontSize="10"
                                               FontWeight="SemiBold"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                </Border>
                            </StackPanel>

                            <StackPanel Grid.Row="0"
                                        Grid.Column="8"
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Bottom"
                                        Margin="8,0,0,6">
                                <TextBlock Text="Reg addr"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                                <Border Margin="7,0,0,0"
                                        Width="16"
                                        Height="16"
                                        CornerRadius="8"
                                        Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                        VerticalAlignment="Center"
                                        Cursor="Help"
                                        ToolTipService.ShowDuration="20000">
                                    <Border.ToolTip>
                                        <ToolTip>
                                            <TextBlock MaxWidth="280"
                                                       TextWrapping="Wrap"
                                                       Text="Custom EC register ID (hex). Leave empty to use the default. Use this if your laptop uses different register IDs. Find values on ThinkWiki or via trial &amp; error with the Custom EC Write dialog."/>
                                        </ToolTip>
                                    </Border.ToolTip>
                                    <TextBlock Text="?"
                                               FontSize="10"
                                               FontWeight="SemiBold"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                </Border>
                            </StackPanel>

                            <!-- ── Power ── -->
                            <TextBlock Grid.Row="1"
                                       Grid.Column="0"
                                       Text="Power"
                                       VerticalAlignment="Center"
                                       Margin="4,6,20,6"/>
                            <RadioButton Grid.Row="1"
                                         Grid.Column="1"
                                         GroupName="g_Power"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,16,6"
                                         IsChecked="{Binding MainVm.Power.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static root:LedMode.Default}}"/>
                            <RadioButton Grid.Row="1"
                                         Grid.Column="2"
                                         GroupName="g_Power"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,16,6"
                                         IsChecked="{Binding MainVm.Power.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static root:LedMode.On}}"/>
                            <RadioButton Grid.Row="1"
                                         Grid.Column="3"
                                         GroupName="g_Power"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,16,6"
                                         IsChecked="{Binding MainVm.Power.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static root:LedMode.Off}}"/>
                            <RadioButton Grid.Row="1"
                                         Grid.Column="4"
                                         GroupName="g_Power"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,16,6"
                                         IsChecked="{Binding MainVm.Power.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static root:LedMode.Blink}}"/>
                            <RadioButton Grid.Row="1"
                                         Grid.Column="5"
                                         GroupName="g_Power"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,16,6"
                                         IsChecked="{Binding MainVm.Power.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static root:LedMode.HotkeyControlled}}"/>
                            <RadioButton Grid.Row="1"
                                         Grid.Column="6"
                                         GroupName="g_Power"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,16,6"
                                         IsEnabled="{Binding MainVm.DiskRadiosEnabled}"
                                         ToolTipService.ShowOnDisabled="True"
                                         IsChecked="{Binding MainVm.Power.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static root:LedMode.DiskWrite}}">
                                <RadioButton.Style>
                                    <Style TargetType="RadioButton"
                                           BasedOn="{StaticResource {x:Type RadioButton}}">
                                        <Style.Triggers>
                                            <Trigger Property="IsEnabled"
                                                     Value="False">
                                                <Setter Property="ToolTip"
                                                        Value="Disabled: disk monitoring is unavailable on your device."/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </RadioButton.Style>
                            </RadioButton>
                            <RadioButton Grid.Row="1"
                                         Grid.Column="7"
                                         GroupName="g_Power"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,0,6"
                                         IsEnabled="{Binding MainVm.DiskRadiosEnabled}"
                                         ToolTipService.ShowOnDisabled="True"
                                         IsChecked="{Binding MainVm.Power.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static root:LedMode.DiskRead}}">
                                <RadioButton.Style>
                                    <Style TargetType="RadioButton"
                                           BasedOn="{StaticResource {x:Type RadioButton}}">
                                        <Style.Triggers>
                                            <Trigger Property="IsEnabled"
                                                     Value="False">
                                                <Setter Property="ToolTip"
                                                        Value="Disabled: disk monitoring is unavailable on your device."/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </RadioButton.Style>
                            </RadioButton>
                            <TextBox Grid.Row="1"
                                     Grid.Column="8"
                                     Width="40"
                                     Margin="8,4,0,4"
                                     MaxLength="2"
                                     CharacterCasing="Upper"
                                     ToolTip="Hex register ID (e.g., 00). Leave empty for default."
                                     Text="{Binding MainVm.Power.CustomRegisterId, Converter={StaticResource HexByte}, UpdateSourceTrigger=PropertyChanged}"/>

                            <!-- ── Mute ── -->
                            <TextBlock Grid.Row="2"
                                       Grid.Column="0"
                                       Text="Mute"
                                       VerticalAlignment="Center"
                                       Margin="4,6,20,6"/>
                            <RadioButton Grid.Row="2"
                                         Grid.Column="1"
                                         GroupName="g_Mute"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,16,6"
                                         IsChecked="{Binding MainVm.Mute.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static root:LedMode.Default}}"/>
                            <RadioButton Grid.Row="2"
                                         Grid.Column="2"
                                         GroupName="g_Mute"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,16,6"
                                         IsChecked="{Binding MainVm.Mute.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static root:LedMode.On}}"/>
                            <RadioButton Grid.Row="2"
                                         Grid.Column="3"
                                         GroupName="g_Mute"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,16,6"
                                         IsChecked="{Binding MainVm.Mute.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static root:LedMode.Off}}"/>
                            <RadioButton Grid.Row="2"
                                         Grid.Column="4"
                                         GroupName="g_Mute"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,16,6"
                                         IsChecked="{Binding MainVm.Mute.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static root:LedMode.Blink}}"/>
                            <RadioButton Grid.Row="2"
                                         Grid.Column="5"
                                         GroupName="g_Mute"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,16,6"
                                         IsChecked="{Binding MainVm.Mute.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static root:LedMode.HotkeyControlled}}"/>
                            <RadioButton Grid.Row="2"
                                         Grid.Column="6"
                                         GroupName="g_Mute"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,16,6"
                                         IsEnabled="{Binding MainVm.DiskRadiosEnabled}"
                                         ToolTipService.ShowOnDisabled="True"
                                         IsChecked="{Binding MainVm.Mute.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static root:LedMode.DiskWrite}}">
                                <RadioButton.Style>
                                    <Style TargetType="RadioButton"
                                           BasedOn="{StaticResource {x:Type RadioButton}}">
                                        <Style.Triggers>
                                            <Trigger Property="IsEnabled"
                                                     Value="False">
                                                <Setter Property="ToolTip"
                                                        Value="Disabled: disk monitoring is unavailable on your device."/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </RadioButton.Style>
                            </RadioButton>
                            <RadioButton Grid.Row="2"
                                         Grid.Column="7"
                                         GroupName="g_Mute"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,0,6"
                                         IsEnabled="{Binding MainVm.DiskRadiosEnabled}"
                                         ToolTipService.ShowOnDisabled="True"
                                         IsChecked="{Binding MainVm.Mute.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static root:LedMode.DiskRead}}">
                                <RadioButton.Style>
                                    <Style TargetType="RadioButton"
                                           BasedOn="{StaticResource {x:Type RadioButton}}">
                                        <Style.Triggers>
                                            <Trigger Property="IsEnabled"
                                                     Value="False">
                                                <Setter Property="ToolTip"
                                                        Value="Disabled: disk monitoring is unavailable on your device."/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </RadioButton.Style>
                            </RadioButton>
                            <TextBox Grid.Row="2"
                                     Grid.Column="8"
                                     Width="40"
                                     Margin="8,4,0,4"
                                     MaxLength="2"
                                     CharacterCasing="Upper"
                                     ToolTip="Hex register ID (e.g., 04). Leave empty for default."
                                     Text="{Binding MainVm.Mute.CustomRegisterId, Converter={StaticResource HexByte}, UpdateSourceTrigger=PropertyChanged}"/>

                            <!-- ── Red Dot ── -->
                            <TextBlock Grid.Row="3"
                                       Grid.Column="0"
                                       Text="Red Dot"
                                       VerticalAlignment="Center"
                                       Margin="4,6,20,6"/>
                            <RadioButton Grid.Row="3"
                                         Grid.Column="1"
                                         GroupName="g_RedDot"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,16,6"
                                         IsChecked="{Binding MainVm.RedDot.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static root:LedMode.Default}}"/>
                            <RadioButton Grid.Row="3"
                                         Grid.Column="2"
                                         GroupName="g_RedDot"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,16,6"
                                         IsChecked="{Binding MainVm.RedDot.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static root:LedMode.On}}"/>
                            <RadioButton Grid.Row="3"
                                         Grid.Column="3"
                                         GroupName="g_RedDot"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,16,6"
                                         IsChecked="{Binding MainVm.RedDot.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static root:LedMode.Off}}"/>
                            <RadioButton Grid.Row="3"
                                         Grid.Column="4"
                                         GroupName="g_RedDot"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,16,6"
                                         IsChecked="{Binding MainVm.RedDot.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static root:LedMode.Blink}}"/>
                            <RadioButton Grid.Row="3"
                                         Grid.Column="5"
                                         GroupName="g_RedDot"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,16,6"
                                         IsChecked="{Binding MainVm.RedDot.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static root:LedMode.HotkeyControlled}}"/>
                            <RadioButton Grid.Row="3"
                                         Grid.Column="6"
                                         GroupName="g_RedDot"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,16,6"
                                         IsEnabled="{Binding MainVm.DiskRadiosEnabled}"
                                         ToolTipService.ShowOnDisabled="True"
                                         IsChecked="{Binding MainVm.RedDot.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static root:LedMode.DiskWrite}}">
                                <RadioButton.Style>
                                    <Style TargetType="RadioButton"
                                           BasedOn="{StaticResource {x:Type RadioButton}}">
                                        <Style.Triggers>
                                            <Trigger Property="IsEnabled"
                                                     Value="False">
                                                <Setter Property="ToolTip"
                                                        Value="Disabled: disk monitoring is unavailable on your device."/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </RadioButton.Style>
                            </RadioButton>
                            <RadioButton Grid.Row="3"
                                         Grid.Column="7"
                                         GroupName="g_RedDot"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,0,6"
                                         IsEnabled="{Binding MainVm.DiskRadiosEnabled}"
                                         ToolTipService.ShowOnDisabled="True"
                                         IsChecked="{Binding MainVm.RedDot.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static root:LedMode.DiskRead}}">
                                <RadioButton.Style>
                                    <Style TargetType="RadioButton"
                                           BasedOn="{StaticResource {x:Type RadioButton}}">
                                        <Style.Triggers>
                                            <Trigger Property="IsEnabled"
                                                     Value="False">
                                                <Setter Property="ToolTip"
                                                        Value="Disabled: disk monitoring is unavailable on your device."/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </RadioButton.Style>
                            </RadioButton>
                            <TextBox Grid.Row="3"
                                     Grid.Column="8"
                                     Width="40"
                                     Margin="8,4,0,4"
                                     MaxLength="2"
                                     CharacterCasing="Upper"
                                     ToolTip="Hex register ID (e.g., 0A). Leave empty for default."
                                     Text="{Binding MainVm.RedDot.CustomRegisterId, Converter={StaticResource HexByte}, UpdateSourceTrigger=PropertyChanged}"/>

                            <!-- ── Microphone ── -->
                            <TextBlock Grid.Row="4"
                                       Grid.Column="0"
                                       Text="Microphone"
                                       VerticalAlignment="Center"
                                       Margin="4,6,20,6"/>
                            <RadioButton Grid.Row="4"
                                         Grid.Column="1"
                                         GroupName="g_Microphone"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,16,6"
                                         IsChecked="{Binding MainVm.Microphone.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static root:LedMode.Default}}"/>
                            <RadioButton Grid.Row="4"
                                         Grid.Column="2"
                                         GroupName="g_Microphone"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,16,6"
                                         IsChecked="{Binding MainVm.Microphone.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static root:LedMode.On}}"/>
                            <RadioButton Grid.Row="4"
                                         Grid.Column="3"
                                         GroupName="g_Microphone"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,16,6"
                                         IsChecked="{Binding MainVm.Microphone.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static root:LedMode.Off}}"/>
                            <RadioButton Grid.Row="4"
                                         Grid.Column="4"
                                         GroupName="g_Microphone"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,16,6"
                                         IsChecked="{Binding MainVm.Microphone.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static root:LedMode.Blink}}"/>
                            <RadioButton Grid.Row="4"
                                         Grid.Column="5"
                                         GroupName="g_Microphone"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,16,6"
                                         IsChecked="{Binding MainVm.Microphone.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static root:LedMode.HotkeyControlled}}"/>
                            <RadioButton Grid.Row="4"
                                         Grid.Column="6"
                                         GroupName="g_Microphone"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,16,6"
                                         IsEnabled="{Binding MainVm.DiskRadiosEnabled}"
                                         ToolTipService.ShowOnDisabled="True"
                                         IsChecked="{Binding MainVm.Microphone.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static root:LedMode.DiskWrite}}">
                                <RadioButton.Style>
                                    <Style TargetType="RadioButton"
                                           BasedOn="{StaticResource {x:Type RadioButton}}">
                                        <Style.Triggers>
                                            <Trigger Property="IsEnabled"
                                                     Value="False">
                                                <Setter Property="ToolTip"
                                                        Value="Disabled: disk monitoring is unavailable on your device."/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </RadioButton.Style>
                            </RadioButton>
                            <RadioButton Grid.Row="4"
                                         Grid.Column="7"
                                         GroupName="g_Microphone"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,0,6"
                                         IsEnabled="{Binding MainVm.DiskRadiosEnabled}"
                                         ToolTipService.ShowOnDisabled="True"
                                         IsChecked="{Binding MainVm.Microphone.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static root:LedMode.DiskRead}}">
                                <RadioButton.Style>
                                    <Style TargetType="RadioButton"
                                           BasedOn="{StaticResource {x:Type RadioButton}}">
                                        <Style.Triggers>
                                            <Trigger Property="IsEnabled"
                                                     Value="False">
                                                <Setter Property="ToolTip"
                                                        Value="Disabled: disk monitoring is unavailable on your device."/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </RadioButton.Style>
                            </RadioButton>
                            <TextBox Grid.Row="4"
                                     Grid.Column="8"
                                     Width="40"
                                     Margin="8,4,0,4"
                                     MaxLength="2"
                                     CharacterCasing="Upper"
                                     ToolTip="Hex register ID (e.g., 0E). Leave empty for default."
                                     Text="{Binding MainVm.Microphone.CustomRegisterId, Converter={StaticResource HexByte}, UpdateSourceTrigger=PropertyChanged}"/>

                            <!-- ── Sleep ── -->
                            <TextBlock Grid.Row="5"
                                       Grid.Column="0"
                                       Text="Sleep"
                                       VerticalAlignment="Center"
                                       Margin="4,6,20,6"/>
                            <RadioButton Grid.Row="5"
                                         Grid.Column="1"
                                         GroupName="g_Sleep"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,16,6"
                                         IsChecked="{Binding MainVm.Sleep.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static root:LedMode.Default}}"/>
                            <RadioButton Grid.Row="5"
                                         Grid.Column="2"
                                         GroupName="g_Sleep"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,16,6"
                                         IsChecked="{Binding MainVm.Sleep.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static root:LedMode.On}}"/>
                            <RadioButton Grid.Row="5"
                                         Grid.Column="3"
                                         GroupName="g_Sleep"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,16,6"
                                         IsChecked="{Binding MainVm.Sleep.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static root:LedMode.Off}}"/>
                            <RadioButton Grid.Row="5"
                                         Grid.Column="4"
                                         GroupName="g_Sleep"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,16,6"
                                         IsChecked="{Binding MainVm.Sleep.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static root:LedMode.Blink}}"/>
                            <RadioButton Grid.Row="5"
                                         Grid.Column="5"
                                         GroupName="g_Sleep"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,16,6"
                                         IsChecked="{Binding MainVm.Sleep.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static root:LedMode.HotkeyControlled}}"/>
                            <RadioButton Grid.Row="5"
                                         Grid.Column="6"
                                         GroupName="g_Sleep"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,16,6"
                                         IsEnabled="{Binding MainVm.DiskRadiosEnabled}"
                                         ToolTipService.ShowOnDisabled="True"
                                         IsChecked="{Binding MainVm.Sleep.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static root:LedMode.DiskWrite}}">
                                <RadioButton.Style>
                                    <Style TargetType="RadioButton"
                                           BasedOn="{StaticResource {x:Type RadioButton}}">
                                        <Style.Triggers>
                                            <Trigger Property="IsEnabled"
                                                     Value="False">
                                                <Setter Property="ToolTip"
                                                        Value="Disabled: disk monitoring is unavailable on your device."/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </RadioButton.Style>
                            </RadioButton>
                            <RadioButton Grid.Row="5"
                                         Grid.Column="7"
                                         GroupName="g_Sleep"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,0,6"
                                         IsEnabled="{Binding MainVm.DiskRadiosEnabled}"
                                         ToolTipService.ShowOnDisabled="True"
                                         IsChecked="{Binding MainVm.Sleep.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static root:LedMode.DiskRead}}">
                                <RadioButton.Style>
                                    <Style TargetType="RadioButton"
                                           BasedOn="{StaticResource {x:Type RadioButton}}">
                                        <Style.Triggers>
                                            <Trigger Property="IsEnabled"
                                                     Value="False">
                                                <Setter Property="ToolTip"
                                                        Value="Disabled: disk monitoring is unavailable on your device."/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </RadioButton.Style>
                            </RadioButton>
                            <TextBox Grid.Row="5"
                                     Grid.Column="8"
                                     Width="40"
                                     Margin="8,4,0,4"
                                     MaxLength="2"
                                     CharacterCasing="Upper"
                                     ToolTip="Hex register ID (e.g., 07). Leave empty for default."
                                     Text="{Binding MainVm.Sleep.CustomRegisterId, Converter={StaticResource HexByte}, UpdateSourceTrigger=PropertyChanged}"/>

                            <!-- ── Fn Lock ── -->
                            <TextBlock Grid.Row="6"
                                       Grid.Column="0"
                                       Text="Fn/Caps Lock"
                                       VerticalAlignment="Center"
                                       Margin="4,6,20,6"/>
                            <RadioButton Grid.Row="6"
                                         Grid.Column="1"
                                         GroupName="g_FnLock"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,16,6"
                                         IsChecked="{Binding MainVm.FnLock.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static root:LedMode.Default}}"/>
                            <RadioButton Grid.Row="6"
                                         Grid.Column="2"
                                         GroupName="g_FnLock"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,16,6"
                                         IsChecked="{Binding MainVm.FnLock.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static root:LedMode.On}}"/>
                            <RadioButton Grid.Row="6"
                                         Grid.Column="3"
                                         GroupName="g_FnLock"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,16,6"
                                         IsChecked="{Binding MainVm.FnLock.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static root:LedMode.Off}}"/>
                            <RadioButton Grid.Row="6"
                                         Grid.Column="4"
                                         GroupName="g_FnLock"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,16,6"
                                         IsChecked="{Binding MainVm.FnLock.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static root:LedMode.Blink}}"/>
                            <RadioButton Grid.Row="6"
                                         Grid.Column="5"
                                         GroupName="g_FnLock"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,16,6"
                                         IsChecked="{Binding MainVm.FnLock.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static root:LedMode.HotkeyControlled}}"/>
                            <RadioButton Grid.Row="6"
                                         Grid.Column="6"
                                         GroupName="g_FnLock"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,16,6"
                                         IsEnabled="{Binding MainVm.DiskRadiosEnabled}"
                                         ToolTipService.ShowOnDisabled="True"
                                         IsChecked="{Binding MainVm.FnLock.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static root:LedMode.DiskWrite}}">
                                <RadioButton.Style>
                                    <Style TargetType="RadioButton"
                                           BasedOn="{StaticResource {x:Type RadioButton}}">
                                        <Style.Triggers>
                                            <Trigger Property="IsEnabled"
                                                     Value="False">
                                                <Setter Property="ToolTip"
                                                        Value="Disabled: disk monitoring is unavailable on your device."/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </RadioButton.Style>
                            </RadioButton>
                            <RadioButton Grid.Row="6"
                                         Grid.Column="7"
                                         GroupName="g_FnLock"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,0,6"
                                         IsEnabled="{Binding MainVm.DiskRadiosEnabled}"
                                         ToolTipService.ShowOnDisabled="True"
                                         IsChecked="{Binding MainVm.FnLock.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static root:LedMode.DiskRead}}">
                                <RadioButton.Style>
                                    <Style TargetType="RadioButton"
                                           BasedOn="{StaticResource {x:Type RadioButton}}">
                                        <Style.Triggers>
                                            <Trigger Property="IsEnabled"
                                                     Value="False">
                                                <Setter Property="ToolTip"
                                                        Value="Disabled: disk monitoring is unavailable on your device."/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </RadioButton.Style>
                            </RadioButton>
                            <TextBox Grid.Row="6"
                                     Grid.Column="8"
                                     Width="40"
                                     Margin="8,4,0,4"
                                     MaxLength="2"
                                     CharacterCasing="Upper"
                                     ToolTip="Hex register ID (e.g., 06). Leave empty for default."
                                     Text="{Binding MainVm.FnLock.CustomRegisterId, Converter={StaticResource HexByte}, UpdateSourceTrigger=PropertyChanged}"/>

                            <!-- ── Camera ── -->
                            <TextBlock Grid.Row="7"
                                       Grid.Column="0"
                                       Text="Camera"
                                       VerticalAlignment="Center"
                                       Margin="4,6,20,6"/>
                            <RadioButton Grid.Row="7"
                                         Grid.Column="1"
                                         GroupName="g_Camera"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,16,6"
                                         IsChecked="{Binding MainVm.Camera.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static root:LedMode.Default}}"/>
                            <RadioButton Grid.Row="7"
                                         Grid.Column="2"
                                         GroupName="g_Camera"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,16,6"
                                         IsChecked="{Binding MainVm.Camera.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static root:LedMode.On}}"/>
                            <RadioButton Grid.Row="7"
                                         Grid.Column="3"
                                         GroupName="g_Camera"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,16,6"
                                         IsChecked="{Binding MainVm.Camera.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static root:LedMode.Off}}"/>
                            <RadioButton Grid.Row="7"
                                         Grid.Column="4"
                                         GroupName="g_Camera"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,16,6"
                                         IsChecked="{Binding MainVm.Camera.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static root:LedMode.Blink}}"/>
                            <RadioButton Grid.Row="7"
                                         Grid.Column="5"
                                         GroupName="g_Camera"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,16,6"
                                         IsChecked="{Binding MainVm.Camera.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static root:LedMode.HotkeyControlled}}"/>
                            <RadioButton Grid.Row="7"
                                         Grid.Column="6"
                                         GroupName="g_Camera"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,16,6"
                                         IsEnabled="{Binding MainVm.DiskRadiosEnabled}"
                                         ToolTipService.ShowOnDisabled="True"
                                         IsChecked="{Binding MainVm.Camera.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static root:LedMode.DiskWrite}}">
                                <RadioButton.Style>
                                    <Style TargetType="RadioButton"
                                           BasedOn="{StaticResource {x:Type RadioButton}}">
                                        <Style.Triggers>
                                            <Trigger Property="IsEnabled"
                                                     Value="False">
                                                <Setter Property="ToolTip"
                                                        Value="Disabled: disk monitoring is unavailable on your device."/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </RadioButton.Style>
                            </RadioButton>
                            <RadioButton Grid.Row="7"
                                         Grid.Column="7"
                                         GroupName="g_Camera"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,0,6"
                                         IsEnabled="{Binding MainVm.DiskRadiosEnabled}"
                                         ToolTipService.ShowOnDisabled="True"
                                         IsChecked="{Binding MainVm.Camera.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static root:LedMode.DiskRead}}">
                                <RadioButton.Style>
                                    <Style TargetType="RadioButton"
                                           BasedOn="{StaticResource {x:Type RadioButton}}">
                                        <Style.Triggers>
                                            <Trigger Property="IsEnabled"
                                                     Value="False">
                                                <Setter Property="ToolTip"
                                                        Value="Disabled: disk monitoring is unavailable on your device."/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </RadioButton.Style>
                            </RadioButton>
                            <TextBox Grid.Row="7"
                                     Grid.Column="8"
                                     Width="40"
                                     Margin="8,4,0,4"
                                     MaxLength="2"
                                     CharacterCasing="Upper"
                                     ToolTip="Hex register ID (e.g., 0F). Leave empty for default."
                                     Text="{Binding MainVm.Camera.CustomRegisterId, Converter={StaticResource HexByte}, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>
                    </ScrollViewer>
                </ui:Card>



                <!-- ============================================================ -->
                <!-- SECTION 2 — Tab panels                                       -->
                <!-- ============================================================ -->
                <TabControl Margin="0,0,0,0">
                    <!-- ── Hotkey tab ── -->
                    <TabItem Header="Hotkey">
                        <StackPanel Margin="10,12">
                            <TextBlock Text="LEDs assigned to 'Hotkey' cycle through the selected states each time the shortcut is pressed."
                                       Opacity="0.6"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,16"/>
                            <Border x:Name="HotkeyBorder"
                                    CornerRadius="4"
                                    Padding="12,6"
                                    Margin="0,0,0,8"
                                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                                    HorizontalAlignment="Left"
                                    Cursor="Hand"
                                    MouseDown="OnHotkeyBorderClick">
                                <TextBox x:Name="HotkeyTextBox"
                                         Text="{Binding MainVm.HotkeyDisplayText, Mode=OneWay}"
                                         FontFamily="Consolas"
                                         FontSize="14"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         IsReadOnly="True"
                                         IsTabStop="False"
                                         Cursor="Hand"
                                         PreviewKeyDown="OnHotkeyCapture"
                                         GotFocus="OnHotkeyFocused"
                                         LostFocus="OnHotkeyLostFocus"
                                         MinWidth="150"
                                         HorizontalAlignment="Left"/>
                            </Border>
                            <TextBlock Text="Click to change the hotkey combination"
                                       FontSize="11"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       Margin="0,0,0,6"/>

                            <!-- Warning box for hotkey issues -->
                            <Border CornerRadius="4"
                                    Padding="12,8"
                                    Margin="0,0,0,14"
                                    Background="{DynamicResource SystemFillColorCautionBackgroundBrush}"
                                    Visibility="{Binding MainVm.HasHotkeyWarning, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="{Binding MainVm.HotkeyWarningMessage}"
                                           TextWrapping="Wrap"/>
                            </Border>
                            <TextBlock Text="Cycle through..."
                                       FontWeight="SemiBold"
                                       Margin="0,16,0,8"/>
                            <CheckBox Content="On"
                                      IsChecked="{Binding MainVm.HotkeyCycleOn}"
                                      Margin="-8,0,0,6"
                                      Padding="8,4"/>
                            <CheckBox Content="Off"
                                      IsChecked="{Binding MainVm.HotkeyCycleOff}"
                                      Margin="-8,0,0,6"
                                      Padding="8,4"/>
                            <CheckBox Content="Blink"
                                      IsChecked="{Binding MainVm.HotkeyCycleBlink}"
                                      Margin="-8,0,0,0"
                                      Padding="8,4"/>

                        </StackPanel>
                    </TabItem>

                    <!-- ── Blinking tab ── -->
                    <TabItem Header="Blinking">
                        <StackPanel Margin="10,12">
                            <TextBlock Text="Blink interval"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,8"/>
                            <StackPanel Orientation="Horizontal"
                                        VerticalAlignment="Center">
                                <Slider Minimum="100"
                                        Maximum="2000"
                                        Width="200"
                                        Value="{Binding SettingsVm.BlinkIntervalMs}"
                                        TickFrequency="50"
                                        IsSnapToTickEnabled="True"/>
                                <TextBlock Text="{Binding SettingsVm.BlinkIntervalMs, StringFormat={}{0} ms}"
                                           VerticalAlignment="Center"
                                           Width="60"
                                           Margin="8,0,0,0"/>
                            </StackPanel>
                            <TextBlock Text="Controls how fast LEDs blink when set to Blink mode. Lower values = faster blinking."
                                       FontSize="11"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       TextWrapping="Wrap"
                                       Margin="0,8,0,0"/>
                        </StackPanel>
                    </TabItem>

                    <!-- ── Disk tab ── -->
                    <TabItem Header="Disk">
                        <StackPanel Margin="10,12">
                            <!-- Warning shown only when disk counters are unavailable -->
                            <Border CornerRadius="4"
                                    Padding="12,8"
                                    Margin="0,0,0,14"
                                    Background="{DynamicResource SystemFillColorCautionBackgroundBrush}"
                                    Visibility="{Binding MainVm.DiskMonitoringUnavailable, Converter={StaticResource BoolToVis}}">
                                <TextBlock TextWrapping="Wrap"
                                           Text="⚠  Disk performance counters are not available on this system. Disk Read and Disk Write modes will have no effect."/>
                            </Border>

                            <!-- Message shown when no LEDs are using disk monitoring -->
                            <TextBlock Text="No LED is mapped to disk operations, so polling is disabled. You can control the polling interval here once you chose a disk operation in the table above.."
                                       FontStyle="Italic"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility"
                                                Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding MainVm.HasDiskModeLeds}"
                                                         Value="False">
                                                <Setter Property="Visibility"
                                                        Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <!-- Poll interval slider shown when at least one LED is using disk monitoring -->
                            <TextBlock Text="Poll interval"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,8"
                                       Visibility="{Binding MainVm.HasDiskModeLeds, Converter={StaticResource BoolToVis}}"/>
                            <StackPanel Orientation="Horizontal"
                                        VerticalAlignment="Center"
                                        Visibility="{Binding MainVm.HasDiskModeLeds, Converter={StaticResource BoolToVis}}">
                                <Slider Minimum="10"
                                        Maximum="1000"
                                        Width="200"
                                        Value="{Binding SettingsVm.HddPollIntervalMs}"
                                        TickFrequency="10"
                                        IsSnapToTickEnabled="True"/>
                                <TextBlock Text="{Binding SettingsVm.HddPollIntervalMs, StringFormat={}{0} ms}"
                                           VerticalAlignment="Center"
                                           Width="60"
                                           Margin="8,0,0,0"/>
                            </StackPanel>
                            <TextBlock Text="Lower intervals increase CPU usage but provide more responsive LED feedback."
                                       FontSize="11"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       TextWrapping="Wrap"
                                       Margin="0,8,0,0"
                                       Visibility="{Binding MainVm.HasDiskModeLeds, Converter={StaticResource BoolToVis}}"/>
                        </StackPanel>
                    </TabItem>

                    <!-- ── Keyboard Backlight tab ── -->
                    <TabItem Header="Keyboard Backlight">
                        <StackPanel Margin="10,12">
                            <TextBlock Text="Brightness Level"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,8"/>
                            <StackPanel Orientation="Horizontal"
                                        VerticalAlignment="Center">
                                <Slider Grid.Column="0"
                                        Minimum="0"
                                        Maximum="255"
                                        Width="200"
                                        TickFrequency="1"
                                        IsSnapToTickEnabled="True"
                                        Value="{Binding SettingsVm.KeyboardBrightnessLevel}"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding SettingsVm.KeyboardBrightnessPercent, StringFormat={}{0} %}"
                                           VerticalAlignment="Center"
                                           TextAlignment="Right"
                                           Margin="8,0,0,0"/>
                            </StackPanel>

                            <!-- Warning for low brightness values -->
                            <Border CornerRadius="4"
                                    Padding="12,8"
                                    Margin="0,8,0,8"
                                    Background="{DynamicResource SystemFillColorCautionBackgroundBrush}"
                                    Visibility="{Binding SettingsVm.ShowKeyboardBrightnessWarning, Converter={StaticResource BoolToVis}}">
                                <TextBlock TextWrapping="Wrap">
                                    <Run Text="⚠️ Warning: Values below 25% may appear completely off on some ThinkPad models."/>
                                </TextBlock>
                            </Border>

                            <TextBlock Text="Some ThinkPads only support few predefined levels. Value will get floored."
                                       FontSize="11"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,16"/>

                            <TextBlock Text="Additional options"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,8"/>
                            <CheckBox Content="Remember level and restore after sleep or lid-open"
                                      IsChecked="{Binding SettingsVm.RememberKeyboardBacklight}"
                                      Margin="0,0,0,6"
                                      Padding="0,4"/>
                            <CheckBox Content="Dim backlight and LEDs when a fullscreen app is active"
                                      IsChecked="{Binding SettingsVm.DimLedsWhenFullscreen}"
                                      Padding="0,4"/>

                        </StackPanel>
                    </TabItem>

                    <!-- ── App Settings tab ── -->
                    <TabItem Header="App Settings">
                        <StackPanel Margin="10,12">
                            <TextBlock Text="Settings"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,8"/>
                            <CheckBox Content="Start with Windows (runs minimised to tray, no UAC prompt)"
                                      IsChecked="{Binding SettingsVm.StartWithWindows}"
                                      Command="{Binding SettingsVm.ToggleStartupCommand}"
                                      Margin="0,0,0,16"
                                      Padding="0,4"/>
                            <CheckBox Content="Auto-save settings on change (if off, the app will revert to the last saved config when restarted)"
                                      IsChecked="{Binding SettingsVm.PersistSettingsOnChange}"
                                      Margin="0,0,0,16"
                                      Padding="0,4"/>
                            <TextBlock Text="Driver"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding SettingsVm.DriverStatus}"
                                       Opacity="0.6"
                                       Margin="0,0,0,16"/>
                            <TextBlock Text="Version"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,4"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding SettingsVm.AppVersion}"
                                           Opacity="0.6"
                                           Margin="0,0,8,0"/>
                                <TextBlock>
                                    <Hyperlink Click="OnCheckForUpdateClicked">
                                        Check for update
                                    </Hyperlink>
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>
                    </TabItem>

                </TabControl>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</ui:FluentWindow>
