<ui:FluentWindow
    x:Class="ModernThinkPadLEDsController.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:converters="clr-namespace:ModernThinkPadLEDsController.Converters"
    xmlns:root="clr-namespace:ModernThinkPadLEDsController"
    Title="Modern ThinkPad LEDs Controller"
    MinWidth="640"
    MinHeight="400"
    WindowStartupLocation="CenterScreen"
    Closing="Window_Closing">

    <ui:FluentWindow.Resources>
        <converters:EnumToBoolConverter x:Key="EnumToBool"/>
        <BooleanToVisibilityConverter  x:Key="BoolToVis"/>
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0"
                     Title="Modern ThinkPad LEDs Controller"/>

        <!-- Outer vertical scroll covers the whole content area -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      Padding="12"
                      CanContentScroll="false">
            <StackPanel>

                <!-- ============================================================ -->
                <!-- SECTION 1 — LED mode table                                   -->
                <!-- ============================================================ -->
                <ui:Card Padding="12,10"
                         Margin="0,0,0,32">
                    <!-- Horizontal scroll so narrow windows don't clip columns -->
                    <!-- Single grid — header + all LED rows share the same column layout,
                         so alignment is guaranteed without any SharedSizeGroup tricks. -->
                    <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Disabled"
                                  PreviewMouseWheel="TableScrollViewer_PreviewMouseWheel">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <!-- LED name   -->
                                <ColumnDefinition Width="Auto"/>
                                <!-- Default    -->
                                <ColumnDefinition Width="Auto"/>
                                <!-- On         -->
                                <ColumnDefinition Width="Auto"/>
                                <!-- Off        -->
                                <ColumnDefinition Width="Auto"/>
                                <!-- Blink      -->
                                <ColumnDefinition Width="Auto"/>
                                <!-- Hotkey     -->
                                <ColumnDefinition Width="Auto"/>
                                <!-- Disk Write -->
                                <ColumnDefinition Width="Auto"/>
                                <!-- Disk Read  -->
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <!-- header     -->
                                <RowDefinition Height="Auto"/>
                                <!-- Power      -->
                                <RowDefinition Height="Auto"/>
                                <!-- Red Dot    -->
                                <RowDefinition Height="Auto"/>
                                <!-- Microphone -->
                                <RowDefinition Height="Auto"/>
                                <!-- Sleep      -->
                                <RowDefinition Height="Auto"/>
                                <!-- Fn Lock    -->
                            </Grid.RowDefinitions>

                            <!-- ── Header row ── -->
                            <TextBlock Grid.Row="0"
                                       Grid.Column="0"
                                       Text="LED"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Bottom"
                                       Margin="4,0,20,6"/>

                            <StackPanel Grid.Row="0"
                                        Grid.Column="1"
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Bottom"
                                        Margin="8,0,16,6">
                                <TextBlock Text="Default"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                                <Border Margin="7,0,0,0"
                                        Width="16"
                                        Height="16"
                                        CornerRadius="8"
                                        Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                        VerticalAlignment="Center"
                                        Cursor="Help"
                                        ToolTipService.ShowDuration="20000">
                                    <Border.ToolTip>
                                        <ToolTip>
                                            <TextBlock MaxWidth="240"
                                                       TextWrapping="Wrap"
                                                       Text="Let the LED follow the default OS behaviour."/>
                                        </ToolTip>
                                    </Border.ToolTip>
                                    <TextBlock Text="?"
                                               FontSize="10"
                                               FontWeight="SemiBold"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                </Border>
                            </StackPanel>

                            <TextBlock Grid.Row="0"
                                       Grid.Column="2"
                                       Text="On"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="Bottom"
                                       Margin="8,0,16,6"/>
                            <TextBlock Grid.Row="0"
                                       Grid.Column="3"
                                       Text="Off"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="Bottom"
                                       Margin="8,0,16,6"/>
                            <TextBlock Grid.Row="0"
                                       Grid.Column="4"
                                       Text="Blink"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="Bottom"
                                       Margin="8,0,16,6"/>

                            <StackPanel Grid.Row="0"
                                        Grid.Column="5"
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Bottom"
                                        Margin="8,0,16,6">
                                <TextBlock Text="Hotkey"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                                <Border Margin="7,0,0,0"
                                        Width="16"
                                        Height="16"
                                        CornerRadius="8"
                                        Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                        VerticalAlignment="Center"
                                        Cursor="Help"
                                        ToolTipService.ShowDuration="20000">
                                    <Border.ToolTip>
                                        <ToolTip>
                                            <TextBlock MaxWidth="240"
                                                       TextWrapping="Wrap"
                                                       Text="Make the LED cycle through the selected states each time the hotkey is pressed. Configure the states in the Hotkey tab below."/>
                                        </ToolTip>
                                    </Border.ToolTip>
                                    <TextBlock Text="?"
                                               FontSize="10"
                                               FontWeight="SemiBold"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                </Border>
                            </StackPanel>

                            <StackPanel Grid.Row="0"
                                        Grid.Column="6"
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Bottom"
                                        Margin="8,0,16,6">
                                <TextBlock Text="Disk Write"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                                <Border Margin="7,0,0,0"
                                        Width="16"
                                        Height="16"
                                        CornerRadius="8"
                                        Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                        VerticalAlignment="Center"
                                        Cursor="Help"
                                        ToolTipService.ShowDuration="20000">
                                    <Border.ToolTip>
                                        <ToolTip>
                                            <TextBlock MaxWidth="240"
                                                       TextWrapping="Wrap"
                                                       Text="LED turns on whenever a disk write is detected (HDD, SSD, NVMe, ...). Configure the polling interval in the Disk tab below."/>
                                        </ToolTip>
                                    </Border.ToolTip>
                                    <TextBlock Text="?"
                                               FontSize="10"
                                               FontWeight="SemiBold"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                </Border>
                            </StackPanel>

                            <StackPanel Grid.Row="0"
                                        Grid.Column="7"
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Bottom"
                                        Margin="8,0,0,6">
                                <TextBlock Text="Disk Read"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                                <Border Margin="7,0,0,0"
                                        Width="16"
                                        Height="16"
                                        CornerRadius="8"
                                        Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                        VerticalAlignment="Center"
                                        Cursor="Help"
                                        ToolTipService.ShowDuration="20000">
                                    <Border.ToolTip>
                                        <ToolTip>
                                            <TextBlock MaxWidth="240"
                                                       TextWrapping="Wrap"
                                                       Text="LED turns on whenever a disk read is detected (HDD, SSD, NVMe, ...). Configure the polling interval in the Disk tab below."/>
                                        </ToolTip>
                                    </Border.ToolTip>
                                    <TextBlock Text="?"
                                               FontSize="10"
                                               FontWeight="SemiBold"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                </Border>
                            </StackPanel>

                            <!-- ── Power ── -->
                            <TextBlock Grid.Row="1"
                                       Grid.Column="0"
                                       Text="Power"
                                       VerticalAlignment="Center"
                                       Margin="4,6,20,6"/>
                            <RadioButton Grid.Row="1"
                                         Grid.Column="1"
                                         GroupName="g_Power"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,16,6"
                                         IsChecked="{Binding MainVm.Power.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static root:LedMode.Default}}"/>
                            <RadioButton Grid.Row="1"
                                         Grid.Column="2"
                                         GroupName="g_Power"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,16,6"
                                         IsChecked="{Binding MainVm.Power.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static root:LedMode.On}}"/>
                            <RadioButton Grid.Row="1"
                                         Grid.Column="3"
                                         GroupName="g_Power"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,16,6"
                                         IsChecked="{Binding MainVm.Power.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static root:LedMode.Off}}"/>
                            <RadioButton Grid.Row="1"
                                         Grid.Column="4"
                                         GroupName="g_Power"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,16,6"
                                         IsChecked="{Binding MainVm.Power.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static root:LedMode.Blink}}"/>
                            <RadioButton Grid.Row="1"
                                         Grid.Column="5"
                                         GroupName="g_Power"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,16,6"
                                         IsChecked="{Binding MainVm.Power.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static root:LedMode.HotkeyControlled}}"/>
                            <RadioButton Grid.Row="1"
                                         Grid.Column="6"
                                         GroupName="g_Power"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,16,6"
                                         IsEnabled="{Binding MainVm.DiskRadiosEnabled}"
                                         ToolTip="Disabled: disk monitoring is either unavailable or turned off in the Disk tab"
                                         ToolTipService.ShowOnDisabled="True"
                                         IsChecked="{Binding MainVm.Power.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static root:LedMode.DiskWrite}}"/>
                            <RadioButton Grid.Row="1"
                                         Grid.Column="7"
                                         GroupName="g_Power"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,0,6"
                                         IsEnabled="{Binding MainVm.DiskRadiosEnabled}"
                                         ToolTip="Disabled: disk monitoring is either unavailable or turned off in the Disk tab"
                                         ToolTipService.ShowOnDisabled="True"
                                         IsChecked="{Binding MainVm.Power.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static root:LedMode.DiskRead}}"/>

                            <!-- ── Red Dot ── -->
                            <TextBlock Grid.Row="2"
                                       Grid.Column="0"
                                       Text="Red Dot"
                                       VerticalAlignment="Center"
                                       Margin="4,6,20,6"/>
                            <RadioButton Grid.Row="2"
                                         Grid.Column="1"
                                         GroupName="g_RedDot"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,16,6"
                                         IsChecked="{Binding MainVm.RedDot.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static root:LedMode.Default}}"/>
                            <RadioButton Grid.Row="2"
                                         Grid.Column="2"
                                         GroupName="g_RedDot"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,16,6"
                                         IsChecked="{Binding MainVm.RedDot.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static root:LedMode.On}}"/>
                            <RadioButton Grid.Row="2"
                                         Grid.Column="3"
                                         GroupName="g_RedDot"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,16,6"
                                         IsChecked="{Binding MainVm.RedDot.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static root:LedMode.Off}}"/>
                            <RadioButton Grid.Row="2"
                                         Grid.Column="4"
                                         GroupName="g_RedDot"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,16,6"
                                         IsChecked="{Binding MainVm.RedDot.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static root:LedMode.Blink}}"/>
                            <RadioButton Grid.Row="2"
                                         Grid.Column="5"
                                         GroupName="g_RedDot"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,16,6"
                                         IsChecked="{Binding MainVm.RedDot.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static root:LedMode.HotkeyControlled}}"/>
                            <RadioButton Grid.Row="2"
                                         Grid.Column="6"
                                         GroupName="g_RedDot"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,16,6"
                                         IsEnabled="{Binding MainVm.DiskRadiosEnabled}"
                                         ToolTip="Disabled: disk monitoring is either unavailable or turned off in the Disk tab"
                                         ToolTipService.ShowOnDisabled="True"
                                         IsChecked="{Binding MainVm.RedDot.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static root:LedMode.DiskWrite}}"/>
                            <RadioButton Grid.Row="2"
                                         Grid.Column="7"
                                         GroupName="g_RedDot"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,0,6"
                                         IsEnabled="{Binding MainVm.DiskRadiosEnabled}"
                                         ToolTip="Disabled: disk monitoring is either unavailable or turned off in the Disk tab"
                                         ToolTipService.ShowOnDisabled="True"
                                         IsChecked="{Binding MainVm.RedDot.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static root:LedMode.DiskRead}}"/>

                            <!-- ── Microphone ── -->
                            <TextBlock Grid.Row="3"
                                       Grid.Column="0"
                                       Text="Microphone"
                                       VerticalAlignment="Center"
                                       Margin="4,6,20,6"/>
                            <RadioButton Grid.Row="3"
                                         Grid.Column="1"
                                         GroupName="g_Microphone"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,16,6"
                                         IsChecked="{Binding MainVm.Microphone.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static root:LedMode.Default}}"/>
                            <RadioButton Grid.Row="3"
                                         Grid.Column="2"
                                         GroupName="g_Microphone"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,16,6"
                                         IsChecked="{Binding MainVm.Microphone.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static root:LedMode.On}}"/>
                            <RadioButton Grid.Row="3"
                                         Grid.Column="3"
                                         GroupName="g_Microphone"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,16,6"
                                         IsChecked="{Binding MainVm.Microphone.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static root:LedMode.Off}}"/>
                            <RadioButton Grid.Row="3"
                                         Grid.Column="4"
                                         GroupName="g_Microphone"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,16,6"
                                         IsChecked="{Binding MainVm.Microphone.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static root:LedMode.Blink}}"/>
                            <RadioButton Grid.Row="3"
                                         Grid.Column="5"
                                         GroupName="g_Microphone"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,16,6"
                                         IsChecked="{Binding MainVm.Microphone.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static root:LedMode.HotkeyControlled}}"/>
                            <RadioButton Grid.Row="3"
                                         Grid.Column="6"
                                         GroupName="g_Microphone"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,16,6"
                                         IsEnabled="{Binding MainVm.DiskRadiosEnabled}"
                                         ToolTip="Disabled: disk monitoring is either unavailable or turned off in the Disk tab"
                                         ToolTipService.ShowOnDisabled="True"
                                         IsChecked="{Binding MainVm.Microphone.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static root:LedMode.DiskWrite}}"/>
                            <RadioButton Grid.Row="3"
                                         Grid.Column="7"
                                         GroupName="g_Microphone"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,0,6"
                                         IsEnabled="{Binding MainVm.DiskRadiosEnabled}"
                                         ToolTip="Disabled: disk monitoring is either unavailable or turned off in the Disk tab"
                                         ToolTipService.ShowOnDisabled="True"
                                         IsChecked="{Binding MainVm.Microphone.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static root:LedMode.DiskRead}}"/>

                            <!-- ── Sleep ── -->
                            <TextBlock Grid.Row="4"
                                       Grid.Column="0"
                                       Text="Sleep"
                                       VerticalAlignment="Center"
                                       Margin="4,6,20,6"/>
                            <RadioButton Grid.Row="4"
                                         Grid.Column="1"
                                         GroupName="g_Sleep"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,16,6"
                                         IsChecked="{Binding MainVm.Sleep.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static root:LedMode.Default}}"/>
                            <RadioButton Grid.Row="4"
                                         Grid.Column="2"
                                         GroupName="g_Sleep"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,16,6"
                                         IsChecked="{Binding MainVm.Sleep.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static root:LedMode.On}}"/>
                            <RadioButton Grid.Row="4"
                                         Grid.Column="3"
                                         GroupName="g_Sleep"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,16,6"
                                         IsChecked="{Binding MainVm.Sleep.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static root:LedMode.Off}}"/>
                            <RadioButton Grid.Row="4"
                                         Grid.Column="4"
                                         GroupName="g_Sleep"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,16,6"
                                         IsChecked="{Binding MainVm.Sleep.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static root:LedMode.Blink}}"/>
                            <RadioButton Grid.Row="4"
                                         Grid.Column="5"
                                         GroupName="g_Sleep"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,16,6"
                                         IsChecked="{Binding MainVm.Sleep.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static root:LedMode.HotkeyControlled}}"/>
                            <RadioButton Grid.Row="4"
                                         Grid.Column="6"
                                         GroupName="g_Sleep"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,16,6"
                                         IsEnabled="{Binding MainVm.DiskRadiosEnabled}"
                                         ToolTip="Disabled: disk monitoring is either unavailable or turned off in the Disk tab"
                                         ToolTipService.ShowOnDisabled="True"
                                         IsChecked="{Binding MainVm.Sleep.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static root:LedMode.DiskWrite}}"/>
                            <RadioButton Grid.Row="4"
                                         Grid.Column="7"
                                         GroupName="g_Sleep"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,0,6"
                                         IsEnabled="{Binding MainVm.DiskRadiosEnabled}"
                                         ToolTip="Disabled: disk monitoring is either unavailable or turned off in the Disk tab"
                                         ToolTipService.ShowOnDisabled="True"
                                         IsChecked="{Binding MainVm.Sleep.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static root:LedMode.DiskRead}}"/>

                            <!-- ── Fn Lock ── -->
                            <TextBlock Grid.Row="5"
                                       Grid.Column="0"
                                       Text="Fn Lock"
                                       VerticalAlignment="Center"
                                       Margin="4,6,20,6"/>
                            <RadioButton Grid.Row="5"
                                         Grid.Column="1"
                                         GroupName="g_FnLock"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,16,6"
                                         IsChecked="{Binding MainVm.FnLock.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static root:LedMode.Default}}"/>
                            <RadioButton Grid.Row="5"
                                         Grid.Column="2"
                                         GroupName="g_FnLock"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,16,6"
                                         IsChecked="{Binding MainVm.FnLock.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static root:LedMode.On}}"/>
                            <RadioButton Grid.Row="5"
                                         Grid.Column="3"
                                         GroupName="g_FnLock"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,16,6"
                                         IsChecked="{Binding MainVm.FnLock.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static root:LedMode.Off}}"/>
                            <RadioButton Grid.Row="5"
                                         Grid.Column="4"
                                         GroupName="g_FnLock"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,16,6"
                                         IsChecked="{Binding MainVm.FnLock.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static root:LedMode.Blink}}"/>
                            <RadioButton Grid.Row="5"
                                         Grid.Column="5"
                                         GroupName="g_FnLock"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,16,6"
                                         IsChecked="{Binding MainVm.FnLock.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static root:LedMode.HotkeyControlled}}"/>
                            <RadioButton Grid.Row="5"
                                         Grid.Column="6"
                                         GroupName="g_FnLock"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,16,6"
                                         IsEnabled="{Binding MainVm.DiskRadiosEnabled}"
                                         ToolTip="Disabled: disk monitoring is either unavailable or turned off in the Disk tab"
                                         ToolTipService.ShowOnDisabled="True"
                                         IsChecked="{Binding MainVm.FnLock.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static root:LedMode.DiskWrite}}"/>
                            <RadioButton Grid.Row="5"
                                         Grid.Column="7"
                                         GroupName="g_FnLock"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,0,6"
                                         IsEnabled="{Binding MainVm.DiskRadiosEnabled}"
                                         ToolTip="Disabled: disk monitoring is either unavailable or turned off in the Disk tab"
                                         ToolTipService.ShowOnDisabled="True"
                                         IsChecked="{Binding MainVm.FnLock.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static root:LedMode.DiskRead}}"/>
                        </Grid>
                    </ScrollViewer>
                </ui:Card>



                <!-- ============================================================ -->
                <!-- SECTION 2 — Tab panels                                       -->
                <!-- ============================================================ -->
                <TabControl>

                    <!-- ── Hotkey tab ── -->
                    <TabItem Header="Hotkey">
                        <StackPanel Margin="16,12">
                            <TextBlock Text="Shortcut"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,8"/>
                            <Border CornerRadius="4"
                                    Padding="12,6"
                                    Margin="0,0,0,14"
                                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                                    HorizontalAlignment="Left">
                                <TextBlock Text="Win + Shift + K"
                                           FontFamily="Consolas"
                                           FontSize="14"
                                           HorizontalAlignment="Left"/>
                            </Border>
                            <TextBlock Text="LEDs assigned to 'Hotkey' cycle through the selected states each time the shortcut is pressed."
                                       Opacity="0.6"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,14"/>
                            <TextBlock Text="Cycle through"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,8"/>
                            <CheckBox Content="On"
                                      IsChecked="{Binding MainVm.HotkeyCycleOn}"
                                      Margin="-8,0,0,6"/>
                            <CheckBox Content="Off"
                                      IsChecked="{Binding MainVm.HotkeyCycleOff}"
                                      Margin="-8,0,0,6"/>
                            <CheckBox Content="Blink"
                                      IsChecked="{Binding MainVm.HotkeyCycleBlink}"
                                      Margin="-8,0,0,0"/>
                        </StackPanel>
                    </TabItem>

                    <!-- ── Disk tab ── -->
                    <TabItem Header="Disk">
                        <StackPanel Margin="16,12">
                            <!-- Warning shown only when disk counters are unavailable -->
                            <Border CornerRadius="4"
                                    Padding="12,8"
                                    Margin="0,0,0,14"
                                    Background="{DynamicResource SystemFillColorCautionBackgroundBrush}"
                                    Visibility="{Binding MainVm.DiskMonitoringUnavailable, Converter={StaticResource BoolToVis}}">
                                <TextBlock TextWrapping="Wrap"
                                           Text="⚠  Disk performance counters are not available on this system. Disk Read and Disk Write modes will have no effect."/>
                            </Border>

                            <!-- Message shown when no LEDs are using disk monitoring -->
                            <TextBlock Text="No LED is mapped to disk operations."
                                       FontStyle="Italic"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       Margin="0,0,0,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility"
                                                Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding MainVm.HasDiskModeLeds}"
                                                    Value="False">
                                                <Setter Property="Visibility"
                                                        Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <!-- Poll interval slider shown when at least one LED is using disk monitoring -->
                            <TextBlock Text="Poll interval"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,8"
                                       Visibility="{Binding MainVm.HasDiskModeLeds, Converter={StaticResource BoolToVis}}"/>
                            <StackPanel Orientation="Horizontal"
                                        VerticalAlignment="Center"
                                        Visibility="{Binding MainVm.HasDiskModeLeds, Converter={StaticResource BoolToVis}}">
                                <Slider Minimum="10"
                                        Maximum="1000"
                                        Width="200"
                                        Value="{Binding SettingsVm.HddPollIntervalMs}"
                                        TickFrequency="10"
                                        IsSnapToTickEnabled="True"/>
                                <TextBlock Text="{Binding SettingsVm.HddPollIntervalMs, StringFormat={}{0} ms}"
                                           VerticalAlignment="Center"
                                           Width="60"
                                           Margin="8,0,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </TabItem>

                    <!-- ── Keyboard Backlight tab ── -->
                    <TabItem Header="Keyboard Backlight">
                        <StackPanel Margin="16,12">
                            <TextBlock Text="Level"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,8"/>
                            <StackPanel Orientation="Horizontal"
                                        Margin="0,0,0,14">
                                <Button Content="Off"
                                        Command="{Binding SettingsVm.SetBacklightOffCommand}"
                                        Margin="0,0,6,0"/>
                                <Button Content="Low"
                                        Command="{Binding SettingsVm.SetBacklightLowCommand}"
                                        Margin="0,0,6,0"/>
                                <Button Content="High"
                                        Command="{Binding SettingsVm.SetBacklightHighCommand}"/>
                            </StackPanel>
                            <CheckBox Content="Remember level and restore after sleep or lid-open"
                                      IsChecked="{Binding SettingsVm.RememberKeyboardBacklight}"
                                      Margin="0,0,0,6"/>
                            <CheckBox Content="Dim backlight and LEDs when a fullscreen app is active"
                                      IsChecked="{Binding SettingsVm.DimLedsWhenFullscreen}"/>
                        </StackPanel>
                    </TabItem>

                    <!-- ── App Settings tab ── -->
                    <TabItem Header="App Settings">
                        <StackPanel Margin="16,12">
                            <TextBlock Text="Startup"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,8"/>
                            <CheckBox Content="Start with Windows (runs minimised to tray, no UAC prompt)"
                                      IsChecked="{Binding SettingsVm.StartWithWindows}"
                                      Command="{Binding SettingsVm.ToggleStartupCommand}"
                                      Margin="0,0,0,16"/>
                            <TextBlock Text="Driver"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding SettingsVm.DriverStatus}"
                                       Opacity="0.6"
                                       Margin="0,0,0,16"/>
                            <TextBlock Text="Version"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding SettingsVm.AppVersion}"
                                       Opacity="0.6"/>
                        </StackPanel>
                    </TabItem>

                </TabControl>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</ui:FluentWindow>
