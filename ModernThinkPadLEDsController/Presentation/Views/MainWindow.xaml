<ui:FluentWindow
    x:Class="ModernThinkPadLEDsController.Presentation.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:converters="clr-namespace:ModernThinkPadLEDsController.Presentation.Converters"
    xmlns:lighting="clr-namespace:ModernThinkPadLEDsController.Lighting"
    xmlns:controls="clr-namespace:ModernThinkPadLEDsController.Presentation.Controls"
    Title="Modern ThinkPad LEDs Controller"
    Width="1000"
    Height="700"
    MinWidth="640"
    MinHeight="400"
    WindowStartupLocation="CenterScreen"
    ShowInTaskbar="True"
    Icon="pack://application:,,,/Resources/favicon.ico"
    Closing="OnWindowClosing">

    <ui:FluentWindow.Resources>
        <converters:EnumToBoolConverter x:Key="EnumToBool"/>
        <converters:HexByteConverter x:Key="HexByte"/>
        <BooleanToVisibilityConverter  x:Key="BoolToVis"/>
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0">
            <ui:TitleBar.Header>
                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Image Source="pack://application:,,,/Resources/favicon.ico"
                           Width="20"
                           Height="20"
                           Margin="8,0,0,0"/>
                    <TextBlock Text="Modern ThinkPad LEDs Controller"
                               Margin="8,0,0,0"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </ui:TitleBar.Header>
        </ui:TitleBar>

        <!-- Main vertical scroll for entire page -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      Padding="12"
                      PreviewMouseWheel="MainScrollViewer_PreviewMouseWheel"
                      PanningMode="Both">
            <StackPanel>

                <!-- ============================================================ -->
                <!-- SECTION 1 — LED mode table                                   -->
                <!-- ============================================================ -->
                <ui:Card Padding="12,10"
                         Margin="0,0,0,32">
                    <!-- Horizontal scroll for table only -->
                    <ScrollViewer x:Name="TableScrollViewer"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Disabled"
                                  PreviewMouseWheel="TableScrollViewer_PreviewMouseWheel"
                                  Padding="0,0,0,8"
                                  PanningMode="Both">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <!-- LED name   -->
                                <ColumnDefinition Width="Auto"/>
                                <!-- Default    -->
                                <ColumnDefinition Width="Auto"/>
                                <!-- On         -->
                                <ColumnDefinition Width="Auto"/>
                                <!-- Off        -->
                                <ColumnDefinition Width="Auto"/>
                                <!-- Blink      -->
                                <ColumnDefinition Width="Auto"/>
                                <!-- Hotkey     -->
                                <ColumnDefinition Width="Auto"/>
                                <!-- Disk Write -->
                                <ColumnDefinition Width="Auto"/>
                                <!-- Disk Read  -->
                                <ColumnDefinition Width="Auto"/>
                                <!-- LED Mapping -->
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <!-- header     -->
                                <RowDefinition Height="Auto"/>
                                <!-- Power      -->
                                <RowDefinition Height="Auto"/>
                                <!-- Mute       -->
                                <RowDefinition Height="Auto"/>
                                <!-- Red Dot    -->
                                <RowDefinition Height="Auto"/>
                                <!-- Microphone -->
                                <RowDefinition Height="Auto"/>
                                <!-- Sleep      -->
                                <RowDefinition Height="Auto"/>
                                <!-- Fn Lock    -->
                                <RowDefinition Height="Auto"/>
                                <!-- Camera     -->
                            </Grid.RowDefinitions>

                            <!-- ── Header row ── -->
                            <TextBlock Grid.Row="0"
                                       Grid.Column="0"
                                       Text="LED"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Bottom"
                                       Margin="4,0,20,6"/>

                            <controls:LabelWithHelp Grid.Row="0"
                                                    Grid.Column="1"
                                                    HorizontalAlignment="Left"
                                                    VerticalAlignment="Bottom"
                                                    Margin="8,0,16,6"
                                                    Label="Default"
                                                    FontWeight="SemiBold"
                                                    HelpText="Let the LED follow the default OS behaviour."/>

                            <TextBlock Grid.Row="0"
                                       Grid.Column="2"
                                       Text="On"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="Bottom"
                                       Margin="8,0,16,6"/>
                            <TextBlock Grid.Row="0"
                                       Grid.Column="3"
                                       Text="Off"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="Bottom"
                                       Margin="8,0,16,6"/>
                            <TextBlock Grid.Row="0"
                                       Grid.Column="4"
                                       Text="Blink"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="Bottom"
                                       Margin="8,0,16,6"/>

                            <controls:LabelWithHelp Grid.Row="0"
                                                    Grid.Column="5"
                                                    HorizontalAlignment="Left"
                                                    VerticalAlignment="Bottom"
                                                    Margin="8,0,16,6"
                                                    Label="Hotkey"
                                                    FontWeight="SemiBold"
                                                    HelpText="Make the LED cycle through the selected states each time the hotkey is pressed. Configure the states in the Hotkey tab below."/>

                            <controls:LabelWithHelp Grid.Row="0"
                                                    Grid.Column="6"
                                                    HorizontalAlignment="Left"
                                                    VerticalAlignment="Bottom"
                                                    Margin="8,0,16,6"
                                                    Label="Disk Write"
                                                    FontWeight="SemiBold"
                                                    HelpText="LED turns on whenever disk write activity is detected. Configure the polling interval in the Disk tab below."/>

                            <controls:LabelWithHelp Grid.Row="0"
                                                    Grid.Column="7"
                                                    HorizontalAlignment="Left"
                                                    VerticalAlignment="Bottom"
                                                    Margin="8,0,0,6"
                                                    Label="Disk Read"
                                                    FontWeight="SemiBold"
                                                    HelpText="LED turns on whenever disk read activity is detected. Configure the polling interval in the Disk tab below."/>

                            <controls:LabelWithHelp Grid.Row="0"
                                                    Grid.Column="8"
                                                    HorizontalAlignment="Left"
                                                    VerticalAlignment="Bottom"
                                                    Margin="8,0,0,6"
                                                    Label="Reg addr"
                                                    FontWeight="SemiBold"
                                                    HelpText="Custom EC register ID (hex). Leave empty to use the default. Use this if your laptop uses different register IDs. Find values on ThinkWiki or via trial &amp; error with the Custom EC Write dialog."/>

                            <!-- ── Power ── -->
                            <TextBlock Grid.Row="1"
                                       Grid.Column="0"
                                       Text="Power"
                                       VerticalAlignment="Center"
                                       Margin="4,6,20,6"/>
                            <RadioButton Grid.Row="1"
                                         Grid.Column="1"
                                         GroupName="g_Power"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,16,6"
                                         IsChecked="{Binding MainVm.Power.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static lighting:LedMode.Default}}"/>
                            <RadioButton Grid.Row="1"
                                         Grid.Column="2"
                                         GroupName="g_Power"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,16,6"
                                         IsChecked="{Binding MainVm.Power.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static lighting:LedMode.On}}"/>
                            <RadioButton Grid.Row="1"
                                         Grid.Column="3"
                                         GroupName="g_Power"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,16,6"
                                         IsChecked="{Binding MainVm.Power.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static lighting:LedMode.Off}}"/>
                            <RadioButton Grid.Row="1"
                                         Grid.Column="4"
                                         GroupName="g_Power"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,16,6"
                                         IsChecked="{Binding MainVm.Power.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static lighting:LedMode.Blink}}"/>
                            <RadioButton Grid.Row="1"
                                         Grid.Column="5"
                                         GroupName="g_Power"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,16,6"
                                         IsChecked="{Binding MainVm.Power.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static lighting:LedMode.HotkeyControlled}}"/>
                            <RadioButton Grid.Row="1"
                                         Grid.Column="6"
                                         GroupName="g_Power"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,16,6"
                                         IsEnabled="{Binding MainVm.DiskRadiosEnabled}"
                                         ToolTipService.ShowOnDisabled="True"
                                         IsChecked="{Binding MainVm.Power.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static lighting:LedMode.DiskWrite}}">
                                <RadioButton.Style>
                                    <Style TargetType="RadioButton"
                                           BasedOn="{StaticResource {x:Type RadioButton}}">
                                        <Style.Triggers>
                                            <Trigger Property="IsEnabled"
                                                     Value="False">
                                                <Setter Property="ToolTip"
                                                        Value="Disabled: disk monitoring is unavailable on your device."/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </RadioButton.Style>
                            </RadioButton>
                            <RadioButton Grid.Row="1"
                                         Grid.Column="7"
                                         GroupName="g_Power"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,0,6"
                                         IsEnabled="{Binding MainVm.DiskRadiosEnabled}"
                                         ToolTipService.ShowOnDisabled="True"
                                         IsChecked="{Binding MainVm.Power.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static lighting:LedMode.DiskRead}}">
                                <RadioButton.Style>
                                    <Style TargetType="RadioButton"
                                           BasedOn="{StaticResource {x:Type RadioButton}}">
                                        <Style.Triggers>
                                            <Trigger Property="IsEnabled"
                                                     Value="False">
                                                <Setter Property="ToolTip"
                                                        Value="Disabled: disk monitoring is unavailable on your device."/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </RadioButton.Style>
                            </RadioButton>
                            <controls:HexRegisterInput Grid.Row="1"
                                                       Grid.Column="8"
                                                       HexExample="00"
                                                       Value="{Binding MainVm.Power.CustomRegisterId}"/>

                            <!-- ── Mute ── -->
                            <TextBlock Grid.Row="2"
                                       Grid.Column="0"
                                       Text="Mute"
                                       VerticalAlignment="Center"
                                       Margin="4,6,20,6"/>
                            <RadioButton Grid.Row="2"
                                         Grid.Column="1"
                                         GroupName="g_Mute"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,16,6"
                                         IsChecked="{Binding MainVm.Mute.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static lighting:LedMode.Default}}"/>
                            <RadioButton Grid.Row="2"
                                         Grid.Column="2"
                                         GroupName="g_Mute"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,16,6"
                                         IsChecked="{Binding MainVm.Mute.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static lighting:LedMode.On}}"/>
                            <RadioButton Grid.Row="2"
                                         Grid.Column="3"
                                         GroupName="g_Mute"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,16,6"
                                         IsChecked="{Binding MainVm.Mute.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static lighting:LedMode.Off}}"/>
                            <RadioButton Grid.Row="2"
                                         Grid.Column="4"
                                         GroupName="g_Mute"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,16,6"
                                         IsChecked="{Binding MainVm.Mute.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static lighting:LedMode.Blink}}"/>
                            <RadioButton Grid.Row="2"
                                         Grid.Column="5"
                                         GroupName="g_Mute"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,16,6"
                                         IsChecked="{Binding MainVm.Mute.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static lighting:LedMode.HotkeyControlled}}"/>
                            <RadioButton Grid.Row="2"
                                         Grid.Column="6"
                                         GroupName="g_Mute"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,16,6"
                                         IsEnabled="{Binding MainVm.DiskRadiosEnabled}"
                                         ToolTipService.ShowOnDisabled="True"
                                         IsChecked="{Binding MainVm.Mute.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static lighting:LedMode.DiskWrite}}">
                                <RadioButton.Style>
                                    <Style TargetType="RadioButton"
                                           BasedOn="{StaticResource {x:Type RadioButton}}">
                                        <Style.Triggers>
                                            <Trigger Property="IsEnabled"
                                                     Value="False">
                                                <Setter Property="ToolTip"
                                                        Value="Disabled: disk monitoring is unavailable on your device."/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </RadioButton.Style>
                            </RadioButton>
                            <RadioButton Grid.Row="2"
                                         Grid.Column="7"
                                         GroupName="g_Mute"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,0,6"
                                         IsEnabled="{Binding MainVm.DiskRadiosEnabled}"
                                         ToolTipService.ShowOnDisabled="True"
                                         IsChecked="{Binding MainVm.Mute.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static lighting:LedMode.DiskRead}}">
                                <RadioButton.Style>
                                    <Style TargetType="RadioButton"
                                           BasedOn="{StaticResource {x:Type RadioButton}}">
                                        <Style.Triggers>
                                            <Trigger Property="IsEnabled"
                                                     Value="False">
                                                <Setter Property="ToolTip"
                                                        Value="Disabled: disk monitoring is unavailable on your device."/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </RadioButton.Style>
                            </RadioButton>
                            <controls:HexRegisterInput Grid.Row="2"
                                                       Grid.Column="8"
                                                       HexExample="04"
                                                       Value="{Binding MainVm.Mute.CustomRegisterId}"/>

                            <!-- ── Red Dot ── -->
                            <TextBlock Grid.Row="3"
                                       Grid.Column="0"
                                       Text="Red Dot"
                                       VerticalAlignment="Center"
                                       Margin="4,6,20,6"/>
                            <RadioButton Grid.Row="3"
                                         Grid.Column="1"
                                         GroupName="g_RedDot"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,16,6"
                                         IsChecked="{Binding MainVm.RedDot.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static lighting:LedMode.Default}}"/>
                            <RadioButton Grid.Row="3"
                                         Grid.Column="2"
                                         GroupName="g_RedDot"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,16,6"
                                         IsChecked="{Binding MainVm.RedDot.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static lighting:LedMode.On}}"/>
                            <RadioButton Grid.Row="3"
                                         Grid.Column="3"
                                         GroupName="g_RedDot"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,16,6"
                                         IsChecked="{Binding MainVm.RedDot.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static lighting:LedMode.Off}}"/>
                            <RadioButton Grid.Row="3"
                                         Grid.Column="4"
                                         GroupName="g_RedDot"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,16,6"
                                         IsChecked="{Binding MainVm.RedDot.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static lighting:LedMode.Blink}}"/>
                            <RadioButton Grid.Row="3"
                                         Grid.Column="5"
                                         GroupName="g_RedDot"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,16,6"
                                         IsChecked="{Binding MainVm.RedDot.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static lighting:LedMode.HotkeyControlled}}"/>
                            <RadioButton Grid.Row="3"
                                         Grid.Column="6"
                                         GroupName="g_RedDot"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,16,6"
                                         IsEnabled="{Binding MainVm.DiskRadiosEnabled}"
                                         ToolTipService.ShowOnDisabled="True"
                                         IsChecked="{Binding MainVm.RedDot.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static lighting:LedMode.DiskWrite}}">
                                <RadioButton.Style>
                                    <Style TargetType="RadioButton"
                                           BasedOn="{StaticResource {x:Type RadioButton}}">
                                        <Style.Triggers>
                                            <Trigger Property="IsEnabled"
                                                     Value="False">
                                                <Setter Property="ToolTip"
                                                        Value="Disabled: disk monitoring is unavailable on your device."/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </RadioButton.Style>
                            </RadioButton>
                            <RadioButton Grid.Row="3"
                                         Grid.Column="7"
                                         GroupName="g_RedDot"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,0,6"
                                         IsEnabled="{Binding MainVm.DiskRadiosEnabled}"
                                         ToolTipService.ShowOnDisabled="True"
                                         IsChecked="{Binding MainVm.RedDot.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static lighting:LedMode.DiskRead}}">
                                <RadioButton.Style>
                                    <Style TargetType="RadioButton"
                                           BasedOn="{StaticResource {x:Type RadioButton}}">
                                        <Style.Triggers>
                                            <Trigger Property="IsEnabled"
                                                     Value="False">
                                                <Setter Property="ToolTip"
                                                        Value="Disabled: disk monitoring is unavailable on your device."/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </RadioButton.Style>
                            </RadioButton>
                            <controls:HexRegisterInput Grid.Row="3"
                                                       Grid.Column="8"
                                                       HexExample="0A"
                                                       Value="{Binding MainVm.RedDot.CustomRegisterId}"/>

                            <!-- ── Microphone ── -->
                            <TextBlock Grid.Row="4"
                                       Grid.Column="0"
                                       Text="Microphone"
                                       VerticalAlignment="Center"
                                       Margin="4,6,20,6"/>
                            <RadioButton Grid.Row="4"
                                         Grid.Column="1"
                                         GroupName="g_Microphone"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,16,6"
                                         IsChecked="{Binding MainVm.Microphone.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static lighting:LedMode.Default}}"/>
                            <RadioButton Grid.Row="4"
                                         Grid.Column="2"
                                         GroupName="g_Microphone"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,16,6"
                                         IsChecked="{Binding MainVm.Microphone.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static lighting:LedMode.On}}"/>
                            <RadioButton Grid.Row="4"
                                         Grid.Column="3"
                                         GroupName="g_Microphone"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,16,6"
                                         IsChecked="{Binding MainVm.Microphone.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static lighting:LedMode.Off}}"/>
                            <RadioButton Grid.Row="4"
                                         Grid.Column="4"
                                         GroupName="g_Microphone"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,16,6"
                                         IsChecked="{Binding MainVm.Microphone.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static lighting:LedMode.Blink}}"/>
                            <RadioButton Grid.Row="4"
                                         Grid.Column="5"
                                         GroupName="g_Microphone"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,16,6"
                                         IsChecked="{Binding MainVm.Microphone.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static lighting:LedMode.HotkeyControlled}}"/>
                            <RadioButton Grid.Row="4"
                                         Grid.Column="6"
                                         GroupName="g_Microphone"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,16,6"
                                         IsEnabled="{Binding MainVm.DiskRadiosEnabled}"
                                         ToolTipService.ShowOnDisabled="True"
                                         IsChecked="{Binding MainVm.Microphone.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static lighting:LedMode.DiskWrite}}">
                                <RadioButton.Style>
                                    <Style TargetType="RadioButton"
                                           BasedOn="{StaticResource {x:Type RadioButton}}">
                                        <Style.Triggers>
                                            <Trigger Property="IsEnabled"
                                                     Value="False">
                                                <Setter Property="ToolTip"
                                                        Value="Disabled: disk monitoring is unavailable on your device."/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </RadioButton.Style>
                            </RadioButton>
                            <RadioButton Grid.Row="4"
                                         Grid.Column="7"
                                         GroupName="g_Microphone"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,0,6"
                                         IsEnabled="{Binding MainVm.DiskRadiosEnabled}"
                                         ToolTipService.ShowOnDisabled="True"
                                         IsChecked="{Binding MainVm.Microphone.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static lighting:LedMode.DiskRead}}">
                                <RadioButton.Style>
                                    <Style TargetType="RadioButton"
                                           BasedOn="{StaticResource {x:Type RadioButton}}">
                                        <Style.Triggers>
                                            <Trigger Property="IsEnabled"
                                                     Value="False">
                                                <Setter Property="ToolTip"
                                                        Value="Disabled: disk monitoring is unavailable on your device."/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </RadioButton.Style>
                            </RadioButton>
                            <controls:HexRegisterInput Grid.Row="4"
                                                       Grid.Column="8"
                                                       HexExample="0E"
                                                       Value="{Binding MainVm.Microphone.CustomRegisterId}"/>

                            <!-- ── Sleep ── -->
                            <TextBlock Grid.Row="5"
                                       Grid.Column="0"
                                       Text="Sleep"
                                       VerticalAlignment="Center"
                                       Margin="4,6,20,6"/>
                            <RadioButton Grid.Row="5"
                                         Grid.Column="1"
                                         GroupName="g_Sleep"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,16,6"
                                         IsChecked="{Binding MainVm.Sleep.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static lighting:LedMode.Default}}"/>
                            <RadioButton Grid.Row="5"
                                         Grid.Column="2"
                                         GroupName="g_Sleep"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,16,6"
                                         IsChecked="{Binding MainVm.Sleep.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static lighting:LedMode.On}}"/>
                            <RadioButton Grid.Row="5"
                                         Grid.Column="3"
                                         GroupName="g_Sleep"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,16,6"
                                         IsChecked="{Binding MainVm.Sleep.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static lighting:LedMode.Off}}"/>
                            <RadioButton Grid.Row="5"
                                         Grid.Column="4"
                                         GroupName="g_Sleep"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,16,6"
                                         IsChecked="{Binding MainVm.Sleep.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static lighting:LedMode.Blink}}"/>
                            <RadioButton Grid.Row="5"
                                         Grid.Column="5"
                                         GroupName="g_Sleep"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,16,6"
                                         IsChecked="{Binding MainVm.Sleep.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static lighting:LedMode.HotkeyControlled}}"/>
                            <RadioButton Grid.Row="5"
                                         Grid.Column="6"
                                         GroupName="g_Sleep"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,16,6"
                                         IsEnabled="{Binding MainVm.DiskRadiosEnabled}"
                                         ToolTipService.ShowOnDisabled="True"
                                         IsChecked="{Binding MainVm.Sleep.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static lighting:LedMode.DiskWrite}}">
                                <RadioButton.Style>
                                    <Style TargetType="RadioButton"
                                           BasedOn="{StaticResource {x:Type RadioButton}}">
                                        <Style.Triggers>
                                            <Trigger Property="IsEnabled"
                                                     Value="False">
                                                <Setter Property="ToolTip"
                                                        Value="Disabled: disk monitoring is unavailable on your device."/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </RadioButton.Style>
                            </RadioButton>
                            <RadioButton Grid.Row="5"
                                         Grid.Column="7"
                                         GroupName="g_Sleep"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,0,6"
                                         IsEnabled="{Binding MainVm.DiskRadiosEnabled}"
                                         ToolTipService.ShowOnDisabled="True"
                                         IsChecked="{Binding MainVm.Sleep.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static lighting:LedMode.DiskRead}}">
                                <RadioButton.Style>
                                    <Style TargetType="RadioButton"
                                           BasedOn="{StaticResource {x:Type RadioButton}}">
                                        <Style.Triggers>
                                            <Trigger Property="IsEnabled"
                                                     Value="False">
                                                <Setter Property="ToolTip"
                                                        Value="Disabled: disk monitoring is unavailable on your device."/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </RadioButton.Style>
                            </RadioButton>
                            <controls:HexRegisterInput Grid.Row="5"
                                                       Grid.Column="8"
                                                       HexExample="07"
                                                       Value="{Binding MainVm.Sleep.CustomRegisterId}"/>

                            <!-- ── Fn Lock ── -->
                            <TextBlock Grid.Row="6"
                                       Grid.Column="0"
                                       Text="Fn/Caps Lock"
                                       VerticalAlignment="Center"
                                       Margin="4,6,20,6"/>
                            <RadioButton Grid.Row="6"
                                         Grid.Column="1"
                                         GroupName="g_FnLock"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,16,6"
                                         IsChecked="{Binding MainVm.FnLock.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static lighting:LedMode.Default}}"/>
                            <RadioButton Grid.Row="6"
                                         Grid.Column="2"
                                         GroupName="g_FnLock"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,16,6"
                                         IsChecked="{Binding MainVm.FnLock.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static lighting:LedMode.On}}"/>
                            <RadioButton Grid.Row="6"
                                         Grid.Column="3"
                                         GroupName="g_FnLock"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,16,6"
                                         IsChecked="{Binding MainVm.FnLock.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static lighting:LedMode.Off}}"/>
                            <RadioButton Grid.Row="6"
                                         Grid.Column="4"
                                         GroupName="g_FnLock"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,16,6"
                                         IsChecked="{Binding MainVm.FnLock.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static lighting:LedMode.Blink}}"/>
                            <RadioButton Grid.Row="6"
                                         Grid.Column="5"
                                         GroupName="g_FnLock"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,16,6"
                                         IsChecked="{Binding MainVm.FnLock.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static lighting:LedMode.HotkeyControlled}}"/>
                            <RadioButton Grid.Row="6"
                                         Grid.Column="6"
                                         GroupName="g_FnLock"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,16,6"
                                         IsEnabled="{Binding MainVm.DiskRadiosEnabled}"
                                         ToolTipService.ShowOnDisabled="True"
                                         IsChecked="{Binding MainVm.FnLock.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static lighting:LedMode.DiskWrite}}">
                                <RadioButton.Style>
                                    <Style TargetType="RadioButton"
                                           BasedOn="{StaticResource {x:Type RadioButton}}">
                                        <Style.Triggers>
                                            <Trigger Property="IsEnabled"
                                                     Value="False">
                                                <Setter Property="ToolTip"
                                                        Value="Disabled: disk monitoring is unavailable on your device."/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </RadioButton.Style>
                            </RadioButton>
                            <RadioButton Grid.Row="6"
                                         Grid.Column="7"
                                         GroupName="g_FnLock"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,0,6"
                                         IsEnabled="{Binding MainVm.DiskRadiosEnabled}"
                                         ToolTipService.ShowOnDisabled="True"
                                         IsChecked="{Binding MainVm.FnLock.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static lighting:LedMode.DiskRead}}">
                                <RadioButton.Style>
                                    <Style TargetType="RadioButton"
                                           BasedOn="{StaticResource {x:Type RadioButton}}">
                                        <Style.Triggers>
                                            <Trigger Property="IsEnabled"
                                                     Value="False">
                                                <Setter Property="ToolTip"
                                                        Value="Disabled: disk monitoring is unavailable on your device."/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </RadioButton.Style>
                            </RadioButton>
                            <controls:HexRegisterInput Grid.Row="6"
                                                       Grid.Column="8"
                                                       HexExample="06"
                                                       Value="{Binding MainVm.FnLock.CustomRegisterId}"/>

                            <!-- ── Camera ── -->
                            <TextBlock Grid.Row="7"
                                       Grid.Column="0"
                                       Text="Camera"
                                       VerticalAlignment="Center"
                                       Margin="4,6,20,6"/>
                            <RadioButton Grid.Row="7"
                                         Grid.Column="1"
                                         GroupName="g_Camera"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,16,6"
                                         IsChecked="{Binding MainVm.Camera.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static lighting:LedMode.Default}}"/>
                            <RadioButton Grid.Row="7"
                                         Grid.Column="2"
                                         GroupName="g_Camera"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,16,6"
                                         IsChecked="{Binding MainVm.Camera.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static lighting:LedMode.On}}"/>
                            <RadioButton Grid.Row="7"
                                         Grid.Column="3"
                                         GroupName="g_Camera"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,16,6"
                                         IsChecked="{Binding MainVm.Camera.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static lighting:LedMode.Off}}"/>
                            <RadioButton Grid.Row="7"
                                         Grid.Column="4"
                                         GroupName="g_Camera"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,16,6"
                                         IsChecked="{Binding MainVm.Camera.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static lighting:LedMode.Blink}}"/>
                            <RadioButton Grid.Row="7"
                                         Grid.Column="5"
                                         GroupName="g_Camera"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,16,6"
                                         IsChecked="{Binding MainVm.Camera.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static lighting:LedMode.HotkeyControlled}}"/>
                            <RadioButton Grid.Row="7"
                                         Grid.Column="6"
                                         GroupName="g_Camera"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,16,6"
                                         IsEnabled="{Binding MainVm.DiskRadiosEnabled}"
                                         ToolTipService.ShowOnDisabled="True"
                                         IsChecked="{Binding MainVm.Camera.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static lighting:LedMode.DiskWrite}}">
                                <RadioButton.Style>
                                    <Style TargetType="RadioButton"
                                           BasedOn="{StaticResource {x:Type RadioButton}}">
                                        <Style.Triggers>
                                            <Trigger Property="IsEnabled"
                                                     Value="False">
                                                <Setter Property="ToolTip"
                                                        Value="Disabled: disk monitoring is unavailable on your device."/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </RadioButton.Style>
                            </RadioButton>
                            <RadioButton Grid.Row="7"
                                         Grid.Column="7"
                                         GroupName="g_Camera"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="8,6,0,6"
                                         IsEnabled="{Binding MainVm.DiskRadiosEnabled}"
                                         ToolTipService.ShowOnDisabled="True"
                                         IsChecked="{Binding MainVm.Camera.Mode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static lighting:LedMode.DiskRead}}">
                                <RadioButton.Style>
                                    <Style TargetType="RadioButton"
                                           BasedOn="{StaticResource {x:Type RadioButton}}">
                                        <Style.Triggers>
                                            <Trigger Property="IsEnabled"
                                                     Value="False">
                                                <Setter Property="ToolTip"
                                                        Value="Disabled: disk monitoring is unavailable on your device."/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </RadioButton.Style>
                            </RadioButton>
                            <controls:HexRegisterInput Grid.Row="7"
                                                       Grid.Column="8"
                                                       HexExample="0F"
                                                       Value="{Binding MainVm.Camera.CustomRegisterId}"/>
                        </Grid>
                    </ScrollViewer>
                </ui:Card>



                <!-- ============================================================ -->
                <!-- SECTION 2 — Tab panels                                       -->
                <!-- ============================================================ -->
                <TabControl Margin="0,0,0,0">
                    <!-- ── Hotkey tab ── -->
                    <TabItem Header="Hotkey">
                        <StackPanel Margin="10,12">
                            <TextBlock Text="LEDs assigned to 'Hotkey' cycle through the selected states each time the shortcut is pressed."
                                       Opacity="0.6"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,24"/>
                            <Border x:Name="HotkeyBorder"
                                    CornerRadius="4"
                                    Margin="0,0,0,8"
                                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                                    HorizontalAlignment="Left"
                                    Cursor="Hand"
                                    MouseDown="OnHotkeyBorderClick">
                                <TextBox x:Name="HotkeyTextBox"
                                         Text="{Binding MainVm.HotkeyDisplayText, Mode=OneWay}"
                                         FontFamily="Consolas"
                                         FontSize="14"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         IsReadOnly="True"
                                         IsTabStop="False"
                                         Cursor="Hand"
                                         PreviewKeyDown="OnHotkeyCapture"
                                         GotFocus="OnHotkeyFocused"
                                         LostFocus="OnHotkeyLostFocus"
                                         HorizontalAlignment="Left"/>
                            </Border>
                            <TextBlock Text="Click to change the hotkey combination"
                                       FontSize="11"
                                       Opacity="0.6"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       Margin="0,0,0,6"/>
                            <controls:WarningBanner
                                Visibility="{Binding MainVm.HasHotkeyWarning, Converter={StaticResource BoolToVis}}"
                                Margin="0,8,0,16"
                                Message="{Binding MainVm.HotkeyWarningMessage}"/>
                            <TextBlock Text="Cycle through..."
                                       FontWeight="SemiBold"
                                       Margin="0,16,0,8"/>
                            <CheckBox Content="On"
                                      IsChecked="{Binding MainVm.HotkeyCycleOn}"
                                      Margin="-8,0,0,6"
                                      Padding="8,4"/>
                            <CheckBox Content="Off"
                                      IsChecked="{Binding MainVm.HotkeyCycleOff}"
                                      Margin="-8,0,0,6"
                                      Padding="8,4"/>
                            <CheckBox Content="Blink"
                                      IsChecked="{Binding MainVm.HotkeyCycleBlink}"
                                      Margin="-8,0,0,0"
                                      Padding="8,4"/>

                        </StackPanel>
                    </TabItem>

                    <!-- ── Blinking tab ── -->
                    <TabItem Header="Blinking">
                        <StackPanel Margin="10,12">
                            <controls:LabeledSlider
                                Label="Blink interval"
                                Minimum="100"
                                Maximum="2000"
                                Value="{Binding SettingsVm.BlinkIntervalMs}"
                                TickFrequency="50"
                                Unit="ms"
                                Description="Controls how fast LEDs blink when set to Blink mode. Lower values imply faster blinking."/>
                        </StackPanel>
                    </TabItem>

                    <!-- ── Disk tab ── -->
                    <TabItem Header="Disk">
                        <StackPanel Margin="10,12">
                            <!-- Warning shown only when disk counters are unavailable -->
                            <Border CornerRadius="4"
                                    Padding="12,8"
                                    Margin="0,0,0,14"
                                    Background="{DynamicResource SystemFillColorCautionBackgroundBrush}"
                                    Visibility="{Binding MainVm.DiskMonitoringUnavailable, Converter={StaticResource BoolToVis}}">
                                <TextBlock TextWrapping="Wrap"
                                           Text="⚠  Disk performance counters are not available on this system. Disk Read and Disk Write modes will have no effect."/>
                            </Border>

                            <!-- Message shown when no LEDs are using disk monitoring -->
                            <TextBlock Text="No LED is mapped to disk operations, so polling is disabled. You can control the polling interval here once you chose a disk operation in the table above.."
                                       FontStyle="Italic"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility"
                                                Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding MainVm.HasDiskModeLeds}"
                                                         Value="False">
                                                <Setter Property="Visibility"
                                                        Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <controls:LabeledSlider
                                Visibility="{Binding MainVm.HasDiskModeLeds, Converter={StaticResource BoolToVis}}"
                                Label="Poll interval"
                                Minimum="100"
                                Maximum="1000"
                                Value="{Binding SettingsVm.DiskPollIntervalMs}"
                                TickFrequency="50"
                                Unit="ms"
                                Description="Lower intervals increase CPU usage but provide more responsive LED feedback."/>
                        </StackPanel>
                    </TabItem>

                    <!-- ── Keyboard Backlight tab ── -->
                    <TabItem Header="Keyboard Backlight">
                        <StackPanel Margin="10,12">
                            <controls:LabeledSlider
                                Label="Brightness Level"
                                Minimum="0"
                                Maximum="255"
                                Value="{Binding SettingsVm.KeyboardBrightnessLevel}"
                                TickFrequency="1"
                                Unit="%"
                                Description="Some ThinkPads only support few predefined levels. Value will get floored."/>
                            <controls:WarningBanner
                                Margin="0,8,0,0"
                                Visibility="{Binding SettingsVm.ShowKeyboardBrightnessWarning, Converter={StaticResource BoolToVis}}"
                                Message="Values below 25% may appear completely off on some ThinkPad models."/>

                            <TextBlock Text="Additional options"
                                       FontWeight="SemiBold"
                                       Margin="0,24,0,8"/>
                            <CheckBox Content="Remember level and restore after sleep or lid-open"
                                      IsChecked="{Binding SettingsVm.RememberKeyboardBacklight}"
                                      Margin="0,0,0,6"
                                      Padding="0,4"/>
                            <CheckBox Content="Dim backlight and LEDs when a fullscreen app is active"
                                      IsChecked="{Binding SettingsVm.DimLedsWhenFullscreen}"
                                      Padding="0,4"/>

                        </StackPanel>
                    </TabItem>

                    <!-- ── App Settings tab ── -->
                    <TabItem Header="App Settings">
                        <StackPanel Margin="10,12">
                            <TextBlock Text="Settings"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,8"/>
                            <CheckBox Content="Start with Windows (runs minimised to tray, no UAC prompt)"
                                      IsChecked="{Binding SettingsVm.StartWithWindows}"
                                      Command="{Binding SettingsVm.ToggleStartupCommand}"
                                      Margin="0,0,0,16"
                                      Padding="0,4"/>
                            <Border CornerRadius="4"
                                    Padding="12,8"
                                    Margin="0,0,0,16"
                                    Background="{DynamicResource SystemFillColorCautionBackgroundBrush}"
                                    Visibility="{Binding SettingsVm.HasStartupTaskWarning, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="{Binding SettingsVm.StartupTaskWarningMessage}"
                                           TextWrapping="Wrap"/>
                            </Border>
                            <CheckBox Content="Auto-save settings on change (if off, the app will revert to the last saved config when restarted)"
                                      IsChecked="{Binding SettingsVm.PersistSettingsOnChange}"
                                      Margin="0,0,0,16"
                                      Padding="0,4"/>
                            <CheckBox Content="Enable hardware access to PawnIO and the EC (turning off applies immediately; turning back on requires restart)"
                                      IsChecked="{Binding SettingsVm.EnableHardwareAccess}"
                                      Margin="0,0,0,0"
                                      Padding="0,4"/>
                            <controls:WarningBanner
                                Visibility="{Binding SettingsVm.HasHardwareAccessWarning, Converter={StaticResource BoolToVis}}"
                                Margin="0,8,0,0"
                                Message="{Binding SettingsVm.HardwareAccessWarningMessage}"/>
                            <controls:LabeledSlider
                                Label="LED re-apply interval"
                                Margin="0,24,0,0"
                                Minimum="250"
                                Maximum="3000"
                                Value="{Binding SettingsVm.LedReapplyIntervalMs}"
                                TickFrequency="250"
                                Unit="ms"
                                Description="How often the app re-asserts user-controlled LED states when firmware or the OS changes them externally. Lower values react faster but cause more EC traffic."/>
                            <TextBlock Text="Driver"
                                       FontWeight="SemiBold"
                                       Margin="0,24,0,4"/>
                            <TextBlock Text="{Binding SettingsVm.DriverStatus}"
                                       Opacity="0.6"
                                       Margin="0,0,0,16"/>
                            <TextBlock Text="Version"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,4"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding SettingsVm.AppVersion}"
                                           Opacity="0.6"
                                           Margin="0,0,8,0"/>
                                <TextBlock>
                                    <Hyperlink Click="OnCheckForUpdateClicked">
                                        Check for update
                                    </Hyperlink>
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>
                    </TabItem>

                </TabControl>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</ui:FluentWindow>

