                <!-- ============================================================ -->
                <!-- SECTION 2 â€” Tab panels                                       -->
                <!-- ============================================================ -->
                <TabControl Margin="0,0,0,0"
                            Background="{DynamicResource ApplicationBackgroundBrush}">
                    <!-- â”€â”€ Hotkey tab â”€â”€ -->
                    <TabItem Header="Hotkey">
                        <StackPanel Margin="10,12">
                            <TextBlock Text="LEDs assigned to 'Hotkey' cycle through the selected states each time the shortcut is pressed."
                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,24"/>
                            <Border x:Name="HotkeyBorder"
                                    CornerRadius="4"
                                    Margin="0,0,0,8"
                                    Background="{DynamicResource AppInputBackgroundBrush}"
                                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    HorizontalAlignment="Left"
                                    Cursor="Hand"
                                    MouseDown="OnHotkeyBorderClick">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="BorderBrush"
                                                Value="{DynamicResource ControlStrokeColorDefaultBrush}"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver"
                                                     Value="True">
                                                <Setter Property="BorderBrush"
                                                        Value="{DynamicResource ControlStrokeColorSecondaryBrush}"/>
                                            </Trigger>
                                            <Trigger Property="IsKeyboardFocusWithin"
                                                     Value="True">
                                                <Setter Property="BorderBrush"
                                                        Value="{DynamicResource AccentFillColorDefaultBrush}"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBox x:Name="HotkeyTextBox"
                                         Text="{Binding MainVm.HotkeyDisplayText, Mode=OneWay}"
                                         FontFamily="Consolas"
                                         FontSize="14"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                         IsReadOnly="True"
                                         IsTabStop="False"
                                         Cursor="Hand"
                                         PreviewKeyDown="OnHotkeyCapture"
                                         GotFocus="OnHotkeyFocused"
                                         LostFocus="OnHotkeyLostFocus"
                                         HorizontalAlignment="Left"/>
                            </Border>
                            <TextBlock Text="{Binding HotkeyHintText, Mode=OneWay}"
                                       FontSize="11"
                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                       Margin="0,0,0,6"/>
                            <controls:WarningBanner
                                Visibility="{Binding MainVm.HasHotkeyWarning, Converter={StaticResource BoolToVis}}"
                                Margin="0,8,0,16"
                                Message="{Binding MainVm.HotkeyWarningMessage}"/>
                            <TextBlock Text="Cycle through..."
                                       FontWeight="SemiBold"
                                       Margin="0,16,0,8"/>
                            <CheckBox Content="On"
                                      IsChecked="{Binding MainVm.HotkeyCycleOn}"
                                      Margin="-8,0,0,6"
                                      Padding="8,4"/>
                            <CheckBox Content="Off"
                                      IsChecked="{Binding MainVm.HotkeyCycleOff}"
                                      Margin="-8,0,0,6"
                                      Padding="8,4"/>
                            <CheckBox Content="Blink"
                                      IsChecked="{Binding MainVm.HotkeyCycleBlink}"
                                      Margin="-8,0,0,0"
                                      Padding="8,4"/>

                        </StackPanel>
                    </TabItem>

                    <!-- â”€â”€ Blinking tab â”€â”€ -->
                    <TabItem Header="Blinking">
                        <StackPanel Margin="10,12">
                            <controls:LabeledSlider
                                Label="Blink interval"
                                Minimum="{Binding SettingsVm.MinBlinkIntervalMs}"
                                Maximum="{Binding SettingsVm.MaxBlinkIntervalMs}"
                                Value="{Binding SettingsVm.BlinkIntervalMs}"
                                TickFrequency="50"
                                Unit="ms"
                                Description="Controls how fast LEDs blink when set to Blink mode. Lower values imply faster blinking."/>
                        </StackPanel>
                    </TabItem>

                    <!-- â”€â”€ Disk tab â”€â”€ -->
                    <TabItem Header="Disk">
                        <StackPanel Margin="10,12">
                            <!-- Warning shown only when disk counters are unavailable -->
                            <Border CornerRadius="4"
                                    Padding="12,8"
                                    Margin="0,0,0,14"
                                    Background="{DynamicResource SystemFillColorCautionBackgroundBrush}"
                                    Visibility="{Binding MainVm.DiskMonitoringUnavailable, Converter={StaticResource BoolToVis}}">
                                <TextBlock TextWrapping="Wrap"
                                           Text="âš   Disk performance counters are not available on this system. Disk Read and Disk Write modes will have no effect."/>
                            </Border>

                            <!-- Message shown when no LEDs are using disk monitoring -->
                            <TextBlock Text="No LED is mapped to disk operations, so polling is disabled. You can control the polling interval here once you chose a disk operation in the table above.."
                                       FontStyle="Italic"
                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility"
                                                Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding MainVm.HasDiskModeLeds}"
                                                         Value="False">
                                                <Setter Property="Visibility"
                                                        Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <controls:LabeledSlider
                                Visibility="{Binding MainVm.HasDiskModeLeds, Converter={StaticResource BoolToVis}}"
                                Label="Poll interval"
                                Minimum="{Binding SettingsVm.MinDiskPollIntervalMs}"
                                Maximum="{Binding SettingsVm.MaxDiskPollIntervalMs}"
                                Value="{Binding SettingsVm.DiskPollIntervalMs}"
                                TickFrequency="50"
                                Unit="ms"
                                Description="Lower intervals increase CPU usage but provide more responsive LED feedback."/>
                        </StackPanel>
                    </TabItem>

                    <!-- â”€â”€ Keyboard Backlight tab â”€â”€ -->
                    <TabItem Header="Keyboard Backlight">
                        <StackPanel Margin="10,12">
                            <CheckBox Content="Set custom keyboard brightness level (re-applied every LED interval, see App Settings)"
                                      IsChecked="{Binding SettingsVm.EnforceKeyboardBacklight}"
                                      Padding="0,4"/>
                            <controls:LabeledSlider
                                Visibility="{Binding SettingsVm.ShowKeyboardBrightnessSlider, Converter={StaticResource BoolToVis}}"
                                Label="Brightness Level"
                                Minimum="0"
                                Margin="0,16,0,0"
                                Maximum="255"
                                Value="{Binding SettingsVm.KeyboardBrightnessLevel}"
                                TickFrequency="1"
                                Unit="/ 255"
                                Description="Some ThinkPads only support few predefined levels. Value will get floored."/>

                            <!-- WarningBanner uses MultiBinding style trigger to show only when both conditions are met -->
                            <controls:WarningBanner
                                Margin="0,8,0,0"
                                Message="Values below 25% may appear completely off on some ThinkPad models.">
                                <controls:WarningBanner.Style>
                                    <Style TargetType="controls:WarningBanner">
                                        <Setter Property="Visibility"
                                                Value="Collapsed"/>
                                        <Style.Triggers>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding SettingsVm.ShowKeyboardBrightnessSlider}"
                                                               Value="True"/>
                                                    <Condition Binding="{Binding SettingsVm.ShowKeyboardBrightnessWarning}"
                                                               Value="True"/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Visibility"
                                                        Value="Visible"/>
                                            </MultiDataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </controls:WarningBanner.Style>
                            </controls:WarningBanner>

                            <TextBlock Text="Additional options"
                                       FontWeight="SemiBold"
                                       Margin="0,24,0,8"/>
                            <CheckBox Content="Remember level and restore after sleep or lid-open"
                                      IsChecked="{Binding SettingsVm.RememberKeyboardBacklight}"
                                      Margin="0,0,0,6"
                                      Padding="0,4"/>
                            <CheckBox Content="Dim backlight and LEDs when a fullscreen app is active"
                                      IsChecked="{Binding SettingsVm.DimLedsWhenFullscreen}"
                                      Padding="0,4"/>

                        </StackPanel>
                    </TabItem>

                    <!-- â”€â”€ App Settings tab â”€â”€ -->
                    <TabItem Header="App Settings">
                        <StackPanel Margin="10,12">
                            <TextBlock Text="Settings"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,8"/>
                            <CheckBox Content="Start with Windows (runs minimised to tray, no UAC prompt)"
                                      IsChecked="{Binding SettingsVm.StartWithWindows}"
                                      Command="{Binding SettingsVm.ToggleStartupCommand}"
                                      Margin="0,0,0,16"
                                      Padding="0,4"/>
                            <Border CornerRadius="4"
                                    Padding="12,8"
                                    Margin="0,0,0,16"
                                    Background="{DynamicResource SystemFillColorCautionBackgroundBrush}"
                                    Visibility="{Binding SettingsVm.HasStartupTaskWarning, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="{Binding SettingsVm.StartupTaskWarningMessage}"
                                           TextWrapping="Wrap"/>
                            </Border>
                            <CheckBox Content="Auto-save settings on change (if off, the app will revert to the last saved config when restarted)"
                                      IsChecked="{Binding SettingsVm.PersistSettingsOnChange}"
                                      Margin="0,0,0,16"
                                      Padding="0,4"/>
                            <CheckBox Content="Enable hardware access to PawnIO and the EC (turning off applies immediately; turning back on requires restart)"
                                      IsChecked="{Binding SettingsVm.EnableHardwareAccess}"
                                      Margin="0,0,0,0"
                                      Padding="0,4"/>
                            <controls:WarningBanner
                                Visibility="{Binding SettingsVm.HasHardwareAccessWarning, Converter={StaticResource BoolToVis}}"
                                Margin="0,8,0,0"
                                Message="{Binding SettingsVm.HardwareAccessWarningMessage}"/>
                            <controls:LabeledSlider
                                Label="LED re-apply interval"
                                Margin="0,24,0,0"
                                Minimum="{Binding SettingsVm.MinLedReapplyIntervalMs}"
                                Maximum="{Binding SettingsVm.MaxLedReapplyIntervalMs}"
                                Value="{Binding SettingsVm.LedReapplyIntervalMs}"
                                TickFrequency="250"
                                Unit="ms"
                                Description="How often the app re-asserts user-controlled LED states when firmware or the OS changes them externally. Lower values react faster but cause more EC traffic. To opt-out a LED, set it to 'Default' in the table above."/>
                            <TextBlock Text="Logging Level"
                                       FontWeight="SemiBold"
                                       Margin="0,24,0,4"/>
                            <ComboBox ItemsSource="{Binding SettingsVm.AvailableLogLevels}"
                                      SelectedItem="{Binding SettingsVm.LogLevel}"
                                      Background="{DynamicResource AppInputBackgroundBrush}"
                                      Width="200"
                                      HorizontalAlignment="Left"
                                      Margin="0,8,0,4"/>
                            <TextBlock Text="How detailed logs should be (verbose: highly detailed, errors: only critical errors). More detailed logs can help with troubleshooting but may impact performance and generate large log files over time."
                                       FontSize="11"
                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,0"/>
                            <TextBlock Text="Driver"
                                       FontWeight="SemiBold"
                                       Margin="0,24,0,4"/>
                            <TextBlock Text="{Binding SettingsVm.DriverStatus}"
                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                       Margin="0,0,0,16"/>
                            <TextBlock Text="Version"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,4"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding SettingsVm.AppVersion}"
                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                           Margin="0,0,8,0"/>
                                <TextBlock>
                                    <Hyperlink Click="OnCheckForUpdateClicked">
                                        Check for update
                                    </Hyperlink>
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>
                    </TabItem>

                </TabControl>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</ui:FluentWindow>


