<ui:FluentWindow x:Class="ModernThinkPadLEDsController.Presentation.Views.PawnIOSetupWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="PawnIO Driver Setup"
                 Icon="pack://application:,,,/Resources/favicon.ico"
                 Width="500"
                 SizeToContent="Height"
                 WindowStartupLocation="CenterScreen"
                 ResizeMode="NoResize">

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0"
                   Text="PawnIO Driver Required"
                   FontSize="20"
                   FontWeight="SemiBold"
                   Margin="0,0,0,20"/>

        <!-- Description -->
        <StackPanel Grid.Row="1">
            <TextBlock TextWrapping="Wrap"
                       Margin="0,0,0,15"
                       FontWeight="SemiBold">
                PawnIO driver is not installed or not working.
            </TextBlock>

            <TextBlock TextWrapping="Wrap"
                       Margin="0,0,0,15">
                Modern ThinkPad LEDs Controller requires the PawnIO driver for secure hardware access.
                PawnIO is an open-source kernel driver (GPL-2.0) that provides safe I/O port access.
            </TextBlock>

            <TextBlock TextWrapping="Wrap"
                       Margin="0,0,0,15">
                Click the button below to download and install PawnIO. After installation,
                you can immediately start using this application (no full OS restart needed).
            </TextBlock>

            <TextBlock TextWrapping="Wrap"
                       FontSize="11"
                       Foreground="Gray">
                Source code: https://github.com/namazso/PawnIO
            </TextBlock>
        </StackPanel>

        <!-- Status text (hidden by default) -->
        <TextBlock x:Name="StatusText"
                   Grid.Row="2"
                   TextWrapping="Wrap"
                   Foreground="Red"
                   Margin="0,10,0,10"
                   Visibility="Collapsed"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,40,0,0">
            <ui:Button Content="Cancel"
                       Height="36"
                       VerticalContentAlignment="Center"
                       Click="CancelButton_Click"/>
            <ui:Button x:Name="InstallButton"
                       Appearance="Primary"
                       Margin="10,0,0,0"
                       Click="InstallButton_Click">
                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBlock FontFamily="Segoe Fluent Icons"
                               Text="&#xE896;"
                               Margin="0,0,8,0"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="Download PawnIO"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </ui:Button>

        </StackPanel>
    </Grid>
</ui:FluentWindow>

